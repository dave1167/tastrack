{
  "settings": {
    "options": {
      "nocsrf": true,
      "method": "post"
    }
  },
  "meta": {
    "options": {
      "linkedFile": "/views/users/edit_user.ejs",
      "linkedForm": "frmEditUser"
    },
    "$_POST": [
      {
        "type": "number",
        "name": "userId",
        "options": {
          "rules": {
            "core:required": {
              "param": ""
            }
          }
        }
      },
      {
        "type": "number",
        "name": "tenantUserRoleId",
        "options": {
          "rules": {
            "core:required": {
              "param": ""
            }
          }
        }
      },
      {
        "type": "number",
        "name": "teamMemberId"
      },
      {
        "type": "text",
        "name": "email",
        "options": {
          "rules": {
            "core:required": {
              "param": ""
            },
            "core:email": {}
          }
        }
      },
      {
        "type": "text",
        "name": "fName"
      },
      {
        "type": "text",
        "name": "lName"
      },
      {
        "type": "text",
        "name": "displayName",
        "options": {
          "rules": {
            "core:required": {
              "param": ""
            }
          }
        }
      },
      {
        "type": "boolean",
        "name": "isActive"
      },
      {
        "type": "number",
        "name": "roleId",
        "options": {
          "rules": {
            "core:required": {
              "param": ""
            }
          }
        }
      },
      {
        "type": "number",
        "name": "teamId"
      },
      {
        "type": "number",
        "name": "teamRole"
      }
    ],
    "$_SESSION": [
      {
        "type": "number",
        "name": "TENANT_ID"
      }
    ]
  },
  "exec": {
    "steps": [
      {
        "name": "userBeforeChange",
        "module": "dbupdater",
        "action": "custom",
        "options": {
          "connection": "db",
          "sql": {
            "query": "SELECT u.id,u.displayName,u.email,u.isActive,utr.roleId,tm.teamId FROM tbl_users u INNER JOIN tbl_user_tenant_roles utr ON utr.userId=u.id AND utr.tenantId=:tenantId LEFT JOIN tbl_team_members tm ON tm.tenantUserId=utr.id AND tm.tenantId=utr.tenantId AND tm.isPrimary=1 WHERE u.id=:userId AND utr.id=:tenantUserRoleId LIMIT 1",
            "params": [
              {
                "name": ":tenantId",
                "value": "{{$_SESSION.TENANT_ID}}"
              },
              {
                "name": ":userId",
                "value": "{{$_POST.userId}}"
              },
              {
                "name": ":tenantUserRoleId",
                "value": "{{$_POST.tenantUserRoleId}}"
              }
            ]
          }
        },
        "output": true,
        "outputType": "array"
      },
      {
        "name": "updUser",
        "module": "dbupdater",
        "action": "custom",
        "options": {
          "connection": "db",
          "sql": {
            "query": "UPDATE tbl_users u INNER JOIN tbl_user_tenant_roles utr ON utr.userId=u.id AND utr.tenantId=:tenantId SET u.email=:email,u.fName=:fName,u.lName=:lName,u.displayName=:displayName,u.isActive=:isActive,u.modifiedDate=CURRENT_TIMESTAMP WHERE u.id=:userId AND utr.id=:tenantUserRoleId",
            "params": [
              {
                "name": ":tenantId",
                "value": "{{$_SESSION.TENANT_ID}}"
              },
              {
                "name": ":email",
                "value": "{{$_POST.email.lowercase()}}"
              },
              {
                "name": ":fName",
                "value": "{{$_POST.fName.lowercase().capitalize()}}"
              },
              {
                "name": ":lName",
                "value": "{{$_POST.lName.lowercase().capitalize()}}"
              },
              {
                "name": ":displayName",
                "value": "{{$_POST.displayName}}"
              },
              {
                "name": ":isActive",
                "value": "{{$_POST.isActive}}"
              },
              {
                "name": ":userId",
                "value": "{{$_POST.userId}}"
              },
              {
                "name": ":tenantUserRoleId",
                "value": "{{$_POST.tenantUserRoleId}}"
              }
            ]
          }
        },
        "output": true
      },
      {
        "name": "updTenantRole",
        "module": "dbupdater",
        "action": "custom",
        "options": {
          "connection": "db",
          "sql": {
            "query": "UPDATE tbl_user_tenant_roles SET roleId=:roleId,isActive=:isActive,modifiedDate=CURRENT_TIMESTAMP WHERE id=:tenantUserRoleId AND userId=:userId AND tenantId=:tenantId",
            "params": [
              {
                "name": ":roleId",
                "value": "{{$_POST.roleId}}"
              },
              {
                "name": ":isActive",
                "value": "{{$_POST.isActive}}"
              },
              {
                "name": ":tenantUserRoleId",
                "value": "{{$_POST.tenantUserRoleId}}"
              },
              {
                "name": ":userId",
                "value": "{{$_POST.userId}}"
              },
              {
                "name": ":tenantId",
                "value": "{{$_SESSION.TENANT_ID}}"
              }
            ]
          }
        },
        "output": true
      },
      {
        "name": "saveTeamMembership",
        "module": "core",
        "action": "condition",
        "options": {
          "if": "{{$_POST.teamId && $_POST.teamRole}}",
          "then": {
            "steps": {
              "name": "upsertTeamMember",
              "module": "dbupdater",
              "action": "custom",
              "options": {
                "connection": "db",
                "sql": {
                  "query": "INSERT INTO tbl_team_members (tenantId,tenantUserId,teamId,teamRole,isPrimary,isActive) VALUES (:tenantId,:tenantUserRoleId,:teamId,:teamRole,1,:isActive) ON DUPLICATE KEY UPDATE teamRole=VALUES(teamRole),isPrimary=1,isActive=VALUES(isActive),modifiedDate=CURRENT_TIMESTAMP",
                  "params": [
                    {
                      "name": ":tenantId",
                      "value": "{{$_SESSION.TENANT_ID}}"
                    },
                    {
                      "name": ":tenantUserRoleId",
                      "value": "{{$_POST.tenantUserRoleId}}"
                    },
                    {
                      "name": ":teamId",
                      "value": "{{$_POST.teamId}}"
                    },
                    {
                      "name": ":teamRole",
                      "value": "{{$_POST.teamRole}}"
                    },
                    {
                      "name": ":isActive",
                      "value": "{{$_POST.isActive}}"
                    }
                  ]
                }
              },
              "output": true
            }
          }
        }
      },
      {
        "name": "logUserUpdated",
        "module": "dbupdater",
        "action": "custom",
        "options": {
          "connection": "db",
          "sql": {
            "query": "INSERT INTO tbl_activity_log (tenantId,userId,entityType,entityId,actionType,summary,beforeJson,afterJson,createdDate) SELECT :tenantId,:actorUserId,'user',:targetUserId,'user.updated',CONCAT(:actor,' updated user ',:targetName),JSON_OBJECT('displayName',:oldName,'email',:oldEmail,'isActive',:oldActive,'roleId',:oldRole,'teamId',:oldTeam),JSON_OBJECT('displayName',:newName,'email',:newEmail,'isActive',:newActive,'roleId',:newRole,'teamId',:newTeam),CURRENT_TIMESTAMP FROM tbl_activity_types at WHERE at.tenantId=:tenantId2 AND at.activityKey='user.updated' AND at.isActive=1 LIMIT 1",
            "params": [
              {
                "name": ":tenantId",
                "value": "{{$_SESSION.TENANT_ID}}"
              },
              {
                "name": ":actorUserId",
                "value": "{{$_SESSION.USER_ID}}"
              },
              {
                "name": ":targetUserId",
                "value": "{{$_POST.userId}}"
              },
              {
                "name": ":actor",
                "value": "{{$_SESSION.DISPLAY_NAME.default('A user')}}"
              },
              {
                "name": ":targetName",
                "value": "{{$_POST.displayName}}"
              },
              {
                "name": ":oldName",
                "value": "{{userBeforeChange[0].displayName}}"
              },
              {
                "name": ":oldEmail",
                "value": "{{userBeforeChange[0].email}}"
              },
              {
                "name": ":oldActive",
                "value": "{{userBeforeChange[0].isActive}}"
              },
              {
                "name": ":oldRole",
                "value": "{{userBeforeChange[0].roleId}}"
              },
              {
                "name": ":oldTeam",
                "value": "{{userBeforeChange[0].teamId}}"
              },
              {
                "name": ":newName",
                "value": "{{$_POST.displayName}}"
              },
              {
                "name": ":newEmail",
                "value": "{{$_POST.email.lowercase()}}"
              },
              {
                "name": ":newActive",
                "value": "{{$_POST.isActive}}"
              },
              {
                "name": ":newRole",
                "value": "{{$_POST.roleId}}"
              },
              {
                "name": ":newTeam",
                "value": "{{$_POST.teamId}}"
              },
              {
                "name": ":tenantId2",
                "value": "{{$_SESSION.TENANT_ID}}"
              }
            ]
          }
        },
        "output": true
      }
    ]
  }
}

          "type": "SELECT",
          "query": "SELECT tbl_users.id AS userId,tbl_users.email,tbl_users.fName,tbl_users.lName,tbl_users.displayName,tbl_users.isActive AS userActive,tbl_users.lastLoginDate,tbl_users.modifiedDate,tbl_user_tenant_roles.id AS tenantUserRoleId,tbl_user_tenant_roles.tenantId,tbl_user_tenant_roles.roleId,tbl_tenants.tenantName,tbl_roles.roleName AS accessRole,tbl_roles.description AS accessRoleDesc,tbl_team_members.id AS teamMemberId,tbl_team_members.teamId,tbl_team_members.teamRole AS teamRoleId,tbl_teams.teamName,tbl_team_roles.roleDesc AS teamRoleDesc FROM tbl_users INNER JOIN tbl_user_tenant_roles ON tbl_user_tenant_roles.userId=tbl_users.id INNER JOIN tbl_tenants ON tbl_tenants.id=tbl_user_tenant_roles.tenantId LEFT JOIN tbl_roles ON tbl_roles.id=tbl_user_tenant_roles.roleId LEFT JOIN tbl_team_members ON tbl_team_members.tenantUserId=tbl_user_tenant_roles.id AND tbl_team_members.tenantId=tbl_user_tenant_roles.tenantId AND tbl_team_members.isPrimary=1 LEFT JOIN tbl_teams ON tbl_teams.id=tbl_team_members.teamId AND tbl_teams.tenantId=tbl_team_members.tenantId LEFT JOIN tbl_team_roles ON tbl_team_roles.id=tbl_team_members.teamRole AND tbl_team_roles.teamId=tbl_team_members.teamId AND tbl_team_roles.tenantId=tbl_team_members.tenantId WHERE tbl_users.id=? AND tbl_user_tenant_roles.tenantId=? LIMIT 1;",

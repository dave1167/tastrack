{
  "settings": {
    "options": {
      "method": "post"
    }
  },
  "meta": {
    "options": {
      "linkedFile": "/views/users/create_user.ejs",
      "linkedForm": "frmCreateUser"
    },
    "$_POST": [
      {
        "type": "text",
        "fieldName": "email",
        "options": {
          "rules": {
            "core:required": {
              "param": ""
            },
            "core:email": {}
          }
        },
        "name": "email"
      },
      {
        "type": "text",
        "fieldName": "fName",
        "name": "fName"
      },
      {
        "type": "text",
        "fieldName": "lName",
        "name": "lName"
      },
      {
        "type": "text",
        "fieldName": "displayName",
        "options": {
          "rules": {
            "core:required": {
              "param": ""
            }
          }
        },
        "name": "displayName"
      },
      {
        "type": "text",
        "fieldName": "password",
        "options": {
          "rules": {
            "core:required": {
              "param": ""
            }
          }
        },
        "name": "password"
      },
      {
        "type": "number",
        "fieldName": "roleId",
        "options": {
          "rules": {
            "core:required": {
              "param": ""
            }
          }
        },
        "name": "roleId"
      },
      {
        "type": "number",
        "fieldName": "teamId",
        "options": {
          "rules": {
            "core:required": {
              "param": ""
            }
          }
        },
        "name": "teamId"
      },
      {
        "type": "text",
        "fieldName": "teamRole",
        "options": {
          "rules": {
            "core:required": {
              "param": ""
            }
          }
        },
        "name": "teamRole"
      },
      {
        "type": "text",
        "name": "passwordHash"
      },
      {
        "type": "boolean",
        "name": "isActive"
      },
      {
        "type": "datetime",
        "name": "lastLoginDate"
      },
      {
        "type": "datetime",
        "name": "createdDate"
      },
      {
        "type": "datetime",
        "name": "modifiedDate"
      },
      {
        "type": "text",
        "name": "verifycode"
      },
      {
        "type": "number",
        "name": "userId"
      },
      {
        "type": "text",
        "fieldName": "text1",
        "multiple": true,
        "name": "text1"
      },
      {
        "type": "text",
        "fieldName": "hidTeamId",
        "name": "hidTeamId"
      },
      {
        "type": "text",
        "fieldName": "hidTeamRole",
        "name": "hidTeamRole"
      },
      {
        "type": "number",
        "fieldName": "hidRoleId",
        "options": {
          "rules": {
            "core:number": {}
          }
        },
        "name": "hidRoleId"
      }
    ],
    "$_SESSION": [
      {
        "type": "number",
        "name": "TENANT_ID"
      },
      {
        "type": "number",
        "name": "ROLE_ID"
      }
    ]
  },
  "exec": {
    "steps": [
      {
        "name": "passwordHash",
        "module": "crypto",
        "action": "passwordHash",
        "options": {
          "password": "{{$_POST.password}}",
          "algo": "argon2id"
        },
        "output": true,
        "outputType": "text"
      },
      {
        "name": "",
        "options": {
          "comment": "Create the verification code"
        }
      },
      {
        "name": "accessCode",
        "module": "dbupdater",
        "action": "custom",
        "options": {
          "connection": "db",
          "sql": {
            "query": "SELECT LPAD(FLOOR(RAND() * 1000000), 6, '0') AS accessCode;",
            "params": []
          }
        },
        "output": true,
        "meta": [],
        "outputType": "array",
        "collapsed": true
      },
      {
        "name": "",
        "options": {
          "comment": "check for duplicate emails"
        }
      },
      {
        "name": "validate",
        "module": "validator",
        "action": "validate",
        "options": {
          "data": [
            {
              "name": "email",
              "value": "{{$_POST.email.lowercase()}}",
              "rules": {
                "core:required": {
                  "param": ""
                },
                "core:email": {},
                "db:notexists": {
                  "param": {
                    "connection": "db",
                    "table": "tbl_users",
                    "column": "email"
                  },
                  "message": "A user with this email address already exists. They may already be a member of another organisation. Please search for the existing user and add them to this organisation instead."
                }
              },
              "fieldName": "email"
            }
          ]
        },
        "collapsed": true
      },
      {
        "name": "qryInsertUser",
        "module": "dbupdater",
        "action": "insert",
        "options": {
          "connection": "db",
          "sql": {
            "type": "insert",
            "values": [
              {
                "table": "tbl_users",
                "column": "email",
                "type": "text",
                "value": "{{$_POST.email.lowercase()}}"
              },
              {
                "table": "tbl_users",
                "column": "fName",
                "type": "text",
                "value": "{{$_POST.fName.lowercase().capitalize()}}"
              },
              {
                "table": "tbl_users",
                "column": "lName",
                "type": "text",
                "value": "{{$_POST.lName.lowercase().capitalize()}}"
              },
              {
                "table": "tbl_users",
                "column": "displayName",
                "type": "text",
                "value": "{{$_POST.displayName.lowercase().capitalize()}}"
              },
              {
                "table": "tbl_users",
                "column": "passwordHash",
                "type": "text",
                "value": "{{passwordHash}}"
              },
              {
                "table": "tbl_users",
                "column": "isActive",
                "type": "boolean",
                "value": "1"
              },
              {
                "table": "tbl_users",
                "column": "lastLoginDate",
                "type": "datetime",
                "value": "{{NOW}}"
              },
              {
                "table": "tbl_users",
                "column": "createdDate",
                "type": "datetime",
                "value": "{{NOW.formatDate('yyyy-MM-dd', false)}}"
              },
              {
                "table": "tbl_users",
                "column": "modifiedDate",
                "type": "datetime",
                "value": "{{NOW.formatDate('yyyy-MM-dd', false)}}"
              },
              {
                "table": "tbl_users",
                "column": "verifycode",
                "type": "text",
                "value": "{{accessCode[0].accessCode}}"
              }
            ],
            "table": "tbl_users",
            "returning": "id",
            "query": "insert into `tbl_users` (`createdDate`, `displayName`, `email`, `fName`, `isActive`, `lName`, `lastLoginDate`, `modifiedDate`, `passwordHash`, `verifycode`) values (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)",
            "params": [
              {
                "name": ":P1",
                "type": "expression",
                "value": "{{$_POST.email.lowercase()}}",
                "test": ""
              },
              {
                "name": ":P2",
                "type": "expression",
                "value": "{{$_POST.fName.lowercase().capitalize()}}",
                "test": ""
              },
              {
                "name": ":P3",
                "type": "expression",
                "value": "{{$_POST.lName.lowercase().capitalize()}}",
                "test": ""
              },
              {
                "name": ":P4",
                "type": "expression",
                "value": "{{$_POST.displayName.lowercase().capitalize()}}",
                "test": ""
              },
              {
                "name": ":P5",
                "type": "expression",
                "value": "{{passwordHash}}",
                "test": ""
              },
              {
                "name": ":P6",
                "type": "expression",
                "value": "{{NOW}}",
                "test": ""
              },
              {
                "name": ":P7",
                "type": "expression",
                "value": "{{NOW.formatDate('yyyy-MM-dd', false)}}",
                "test": ""
              },
              {
                "name": ":P8",
                "type": "expression",
                "value": "{{NOW.formatDate('yyyy-MM-dd', false)}}",
                "test": ""
              },
              {
                "name": ":P9",
                "type": "expression",
                "value": "{{accessCode[0].accessCode}}",
                "test": ""
              }
            ]
          }
        },
        "meta": [
          {
            "name": "identity",
            "type": "text"
          },
          {
            "name": "affected",
            "type": "number"
          }
        ],
        "output": true,
        "collapsed": true
      },
      {
        "name": "",
        "module": "core",
        "action": "condition",
        "options": {
          "if": "{{qryInsertUser.affected != 1 || qryInsertUser.identity == ''}}",
          "then": {
            "steps": [
              {
                "name": "errUserInsertFailed",
                "module": "core",
                "action": "error",
                "options": {
                  "message": "The user account could not be created. No records have been saved."
                }
              }
            ]
          },
          "else": {
            "steps": []
          }
        },
        "outputType": "boolean",
        "collapsed": true
      },
      {
        "name": "qryInsTenantRole",
        "module": "dbupdater",
        "action": "insert",
        "options": {
          "connection": "db",
          "sql": {
            "type": "insert",
            "values": [
              {
                "table": "tbl_user_tenant_roles",
                "column": "userId",
                "type": "number",
                "value": "{{qryInsertUser.identity}}"
              },
              {
                "table": "tbl_user_tenant_roles",
                "column": "tenantId",
                "type": "number",
                "value": "{{$_SESSION.TENANT_ID}}"
              },
              {
                "table": "tbl_user_tenant_roles",
                "column": "roleId",
                "type": "number",
                "value": "{{$_POST.hidRoleId}}"
              },
              {
                "table": "tbl_user_tenant_roles",
                "column": "isPrimary",
                "type": "boolean",
                "value": "1"
              },
              {
                "table": "tbl_user_tenant_roles",
                "column": "createdDate",
                "type": "datetime",
                "value": "{{NOW}}"
              },
              {
                "table": "tbl_user_tenant_roles",
                "column": "modifiedDate",
                "type": "datetime",
                "value": "{{NOW}}"
              },
              {
                "table": "tbl_user_tenant_roles",
                "column": "isActive",
                "type": "boolean",
                "value": "1"
              }
            ],
            "table": "tbl_user_tenant_roles",
            "returning": "id",
            "query": "insert into `tbl_user_tenant_roles` (`createdDate`, `isActive`, `isPrimary`, `modifiedDate`, `roleId`, `tenantId`, `userId`) values (?, ?, ?, ?, ?, ?, ?)",
            "params": [
              {
                "name": ":P1",
                "type": "expression",
                "value": "{{qryInsertUser.identity}}",
                "test": ""
              },
              {
                "name": ":P2",
                "type": "expression",
                "value": "{{$_SESSION.TENANT_ID}}",
                "test": ""
              },
              {
                "name": ":P3",
                "type": "expression",
                "value": "{{$_POST.hidRoleId}}",
                "test": ""
              },
              {
                "name": ":P4",
                "type": "expression",
                "value": "{{NOW}}",
                "test": ""
              },
              {
                "name": ":P5",
                "type": "expression",
                "value": "{{NOW}}",
                "test": ""
              }
            ]
          }
        },
        "meta": [
          {
            "name": "identity",
            "type": "text"
          },
          {
            "name": "affected",
            "type": "number"
          }
        ],
        "output": true,
        "collapsed": true
      },
      {
        "name": "",
        "module": "core",
        "action": "condition",
        "options": {
          "if": "{{qryInsTenantRole.affected != 1 || qryInsTenantRole.identity == ''}}",
          "then": {
            "steps": [
              {
                "name": "errTenantRoleInsertFailed",
                "module": "core",
                "action": "error",
                "options": {
                  "message": "The user account was created, but the organisation access could not be assigned."
                }
              }
            ]
          },
          "else": {
            "steps": []
          }
        },
        "outputType": "boolean",
        "collapsed": true
      },
      {
        "name": "qryInsTeamMember",
        "module": "dbupdater",
        "action": "insert",
        "options": {
          "connection": "db",
          "sql": {
            "type": "insert",
            "values": [
              {
                "table": "tbl_team_members",
                "column": "tenantId",
                "type": "number",
                "value": "{{$_SESSION.TENANT_ID}}"
              },
              {
                "table": "tbl_team_members",
                "column": "tenantUserId",
                "type": "number",
                "value": "{{qryInsTenantRole.identity}}"
              },
              {
                "table": "tbl_team_members",
                "column": "teamId",
                "type": "number",
                "value": "{{$_POST.hidTeamId}}"
              },
              {
                "table": "tbl_team_members",
                "column": "teamRole",
                "type": "number",
                "value": "{{$_POST.hidTeamRole}}"
              },
              {
                "table": "tbl_team_members",
                "column": "isPrimary",
                "type": "boolean",
                "value": "1"
              },
              {
                "table": "tbl_team_members",
                "column": "isActive",
                "type": "boolean",
                "value": "1"
              },
              {
                "table": "tbl_team_members",
                "column": "createdDate",
                "type": "datetime",
                "value": "{{NOW}}"
              },
              {
                "table": "tbl_team_members",
                "column": "modifiedDate",
                "type": "datetime",
                "value": "{{NOW}}"
              }
            ],
            "table": "tbl_team_members",
            "returning": "id",
            "query": "insert into `tbl_team_members` (`createdDate`, `isActive`, `isPrimary`, `modifiedDate`, `teamId`, `teamRole`, `tenantId`, `tenantUserId`) values (?, ?, ?, ?, ?, ?, ?, ?)",
            "params": [
              {
                "name": ":P1",
                "type": "expression",
                "value": "{{$_SESSION.TENANT_ID}}",
                "test": ""
              },
              {
                "name": ":P2",
                "type": "expression",
                "value": "{{qryInsTenantRole.identity}}",
                "test": ""
              },
              {
                "name": ":P3",
                "type": "expression",
                "value": "{{$_POST.hidTeamId}}",
                "test": ""
              },
              {
                "name": ":P4",
                "type": "expression",
                "value": "{{$_POST.hidTeamRole}}",
                "test": ""
              },
              {
                "name": ":P5",
                "type": "expression",
                "value": "{{NOW}}",
                "test": ""
              },
              {
                "name": ":P6",
                "type": "expression",
                "value": "{{NOW}}",
                "test": ""
              }
            ]
          }
        },
        "meta": [
          {
            "name": "identity",
            "type": "text"
          },
          {
            "name": "affected",
            "type": "number"
          }
        ],
        "collapsed": true,
        "output": true
      },
      {
        "name": "",
        "module": "core",
        "action": "condition",
        "options": {
          "if": "{{qryInsTeamMember.affected != 1 || qryInsTeamMember.identity == ''}}",
          "then": {
            "steps": [
              {
                "name": "errTeamMemberInsertFailed",
                "module": "core",
                "action": "error",
                "options": {
                  "message": "The user account was created, but the team membership could not be assigned."
                }
              }
            ]
          },
          "else": {
            "steps": []
          }
        },
        "outputType": "boolean",
        "collapsed": true
      },
      {
        "name": "success",
        "module": "core",
        "action": "setvalue",
        "options": {
          "value": {
            "message": "User created successfully",
            "userId": "{{qryInsertUser.identity}}",
            "tenantUserRoleId": "{{qryInsTenantRole.identity}}",
            "teamMemberId": "{{qryInsTeamMember.identity}}"
          }
        },
        "output": true,
        "outputType": "object",
        "collapsed": true
      }
    ]
  },
  "usedModules": {
    "argon2": "^0.30.2"
  }
}
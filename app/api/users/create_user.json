        },
        "output": true,
        "outputType": "text"
      },
      {
        "name": "accessCode",
        "module": "core",
        "action": "setvalue",
        "options": {
          "value": "{{$_POST.lName.encodeBase64().substr(7, 6)}}"
        },
        "meta": [],
        "outputType": "text",
        "output": true
      },
      {
        "name": "qryInsertUser",
        "module": "dbupdater",
        "action": "insert",
        "options": {
          "connection": "db",
          "sql": {
            "type": "insert",
            "values": [
              {
                "table": "tbl_users",
                "column": "email",
                "type": "text",
                "value": "{{$_POST.email.lowercase()}}"
              },
              {
                "table": "tbl_users",
                "column": "fName",
                "type": "text",
                "value": "{{$_POST.fName.lowercase().capitalize()}}"
              },
              {
                "table": "tbl_users",
                "column": "lName",
                "type": "text",
                "value": "{{$_POST.lName.lowercase().capitalize()}}"
              },
              {
                "table": "tbl_users",
                "column": "displayName",
                "type": "text",
                "value": "{{$_POST.displayName.lowercase().capitalize()}}"
              },
              {
                "table": "tbl_users",
                "column": "passwordHash",
                "type": "text",
                "value": "{{passwordHash}}"
              },
              {
                "table": "tbl_users",
                "column": "isActive",
                "type": "boolean",
                "value": "1"
              },
              {
                "table": "tbl_users",
                "column": "lastLoginDate",
                "type": "datetime",
                "value": "{{NOW}}"
              },
              {
                "table": "tbl_users",
                "column": "createdDate",
                "type": "datetime",
                "value": "{{NOW.formatDate('yyyy-MM-dd', false)}}"
              },
              {
                "table": "tbl_users",
                "column": "modifiedDate",
                "type": "datetime",
                "value": "{{NOW.formatDate('yyyy-MM-dd', false)}}"
              },
              {
                "table": "tbl_users",
                "column": "verifycode",
                "type": "text",
                "value": "{{accessCode}}"
              }
            ],
            "table": "tbl_users",
            "returning": "id",
            "query": "insert into `tbl_users` (`createdDate`, `displayName`, `email`, `fName`, `isActive`, `lName`, `lastLoginDate`, `modifiedDate`, `passwordHash`, `verifycode`) values (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)",
            "params": [
              {
                "name": ":P1",
                "type": "expression",
                "value": "{{$_POST.email.lowercase()}}",
                "test": ""
              },
              {
                "name": ":P2",
                "type": "expression",
                "value": "{{$_POST.fName.lowercase().capitalize()}}",
                "test": ""
              },
              {
                "name": ":P3",
                "type": "expression",
                "value": "{{$_POST.lName.lowercase().capitalize()}}",
                "test": ""
              },
              {
                "name": ":P4",
                "type": "expression",
                "value": "{{$_POST.displayName.lowercase().capitalize()}}",
                "test": ""
              },
              {
                "name": ":P5",
                "type": "expression",
                "value": "{{passwordHash}}",
                "test": ""
              },
              {
                "name": ":P6",
                "type": "expression",
                "value": "{{NOW}}",
                "test": ""
              },
              {
                "name": ":P7",
                "type": "expression",
                "value": "{{NOW.formatDate('yyyy-MM-dd', false)}}",
                "test": ""
              },
              {
                "name": ":P8",
                "type": "expression",
                "value": "{{NOW.formatDate('yyyy-MM-dd', false)}}",
                "test": ""
              },
              {
                "name": ":P9",
                "type": "expression",
                "value": "{{accessCode}}",
                "test": ""
              }
            ]
          }
        },
        "meta": [
          {
            "name": "identity",
            "type": "text"
          },
          {
            "name": "affected",
            "type": "number"
          }
        ],
        "output": true,
        "collapsed": true
      },
      {
        "name": "insertTenantRole",
        "module": "dbupdater",
        "action": "custom",
        "options": {
          "connection": "db",
          "sql": {
            "query": "INSERT INTO tbl_user_tenant_roles (userId, tenantId, roleId, isPrimary, isActive) SELECT id, :tenantId, :roleId, 1, 'active' FROM tbl_users WHERE email = :email",
            "params": [
              {
                "name": ":tenantId",
                "value": "{{$_SESSION.TENANT_ID}}",
                "recid": 1
              },
              {
                "name": ":roleId",
                "value": "{{$_POST.roleId}}",
                "recid": 2
              },
              {
                "name": ":email",
                "value": "{{$_POST.email}}",
                "recid": 3
              }
            ]
          }
        },
        "output": true,
        "disabled": true,
        "collapsed": true

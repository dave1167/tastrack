  "exec": {
    "steps": [
      {
        "name": "varTenantId",
        "module": "core",
        "action": "setvalue",
        "options": {
          "value": "{{$_SESSION.TENANT_ID}}"
        },
        "meta": [],
        "outputType": "number",
        "output": true
      },
      {
        "name": "query",
        "module": "dbupdater",
        "action": "custom",
        "options": {
          "connection": "db",
          "sql": {
            "query": "SELECT u.id AS userId,u.fName,u.lName,u.displayName,u.email,u.isActive AS userActive,utr.id AS tenantUserRoleId,utr.tenantId,utr.roleId,r.roleName AS accessRole,tm.id AS teamMemberId,tm.teamId,t.teamName,tm.teamRole AS teamRoleId,tr.roleDesc AS teamRole FROM tbl_user_tenant_roles utr INNER JOIN tbl_users u ON u.id=utr.userId LEFT JOIN tbl_roles r ON r.id=utr.roleId LEFT JOIN tbl_team_members tm ON tm.tenantUserId=utr.id AND tm.tenantId=utr.tenantId AND tm.isPrimary=1 LEFT JOIN tbl_teams t ON t.id=tm.teamId AND t.tenantId=tm.tenantId LEFT JOIN tbl_team_roles tr ON tr.id=tm.teamRole AND tr.teamId=tm.teamId AND tr.tenantId=tm.tenantId WHERE utr.tenantId=? AND utr.isPrimary=1 ORDER BY u.displayName;",
            "params": [
              {
                "name": ":P1",
                "value": "{{$_SESSION.TENANT_ID}}",
                "test": "1"
              }
            ]
          }
        },
        "output": true,
        "meta": [
          {
            "name": "userId",
            "type": "number"
          },

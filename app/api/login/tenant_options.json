{
  "settings": {
    "options": {
      "nocsrf": true,
      "method": "get"
    }
  },
  "exec": {
    "steps": {
      "name": "query",
      "module": "dbupdater",
      "action": "custom",
      "options": {
        "connection": "db",
        "sql": {
          "query": "SELECT DISTINCT t.id AS tenantId, t.tenantName FROM tbl_tenants t INNER JOIN tbl_user_tenant_roles utr ON utr.tenantId = t.id WHERE utr.userId = :userId AND utr.isActive = 1 ORDER BY t.tenantName ASC",
          "params": [
            {
              "name": ":userId",
              "value": "{{$_SESSION.USER_ID}}"
            }
          ]
        }
      },
      "output": true,
      "outputType": "array",
      "meta": [
        {
          "name": "tenantId",
          "type": "number"
        },
        {
          "name": "tenantName",
          "type": "text"
        }
      ],
      "collapsed": true
    }
  }
}
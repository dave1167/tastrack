{
  "settings": {
    "options": {
      "nocsrf": true,
      "method": "post"
    }
  },
  "meta": {
    "$_POST": [
      {
        "type": "number",
        "name": "tenant_id"
      }
    ]
  },
  "exec": {
    "steps": [
      {
        "name": "selectedAccess",
        "module": "dbupdater",
        "action": "custom",
        "options": {
          "connection": "db",
          "sql": {
            "query": "SELECT utr.userId, utr.tenantId, utr.roleId, utr.isPrimary, u.fName, u.lName, u.displayName, t.tenantName, r.roleName, r.roleKey FROM tbl_user_tenant_roles utr INNER JOIN tbl_users u ON u.id = utr.userId INNER JOIN tbl_tenants t ON t.id = utr.tenantId INNER JOIN tbl_roles r ON r.id = utr.roleId WHERE utr.userId = :userId AND utr.tenantId = :tenantId AND utr.isActive = 1 ORDER BY utr.isPrimary DESC, utr.roleId ASC LIMIT 1",
            "params": [
              {
                "name": ":userId",
                "value": "{{$_SESSION.USER_ID}}"
              },
              {
                "name": ":tenantId",
                "value": "{{$_POST.tenant_id}}"
              }
            ]
          }
        },
        "output": true,
        "outputType": "array"
      },
      {
        "name": "TENANT_ID",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{selectedAccess[0].tenantId}}"
        }
      },
      {
        "name": "ROLE_ID",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{selectedAccess[0].roleId}}"
        }
      },
      {
        "name": "TENANT_NAME",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{selectedAccess[0].tenantName}}"
        }
      },
      {
        "name": "FNAME",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{selectedAccess[0].fName}}"
        }
      },
      {
        "name": "LNAME",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{selectedAccess[0].lName}}"
        }
      },
      {
        "name": "DISPLAY_NAME",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{selectedAccess[0].displayName}}"
        }
      },
      {
        "name": "ROLE_NAME",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{selectedAccess[0].roleName}}"
        }
      },
      {
        "name": "ROLE_KEY",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{selectedAccess[0].roleKey}}"
        }
      },
      {
        "name": "logTenantLogin",
        "module": "dbupdater",
        "action": "custom",
        "options": {
          "connection": "db",
          "sql": {
            "query": "INSERT INTO tbl_activity_log (tenantId,userId,entityType,entityId,actionType,summary,afterJson,createdDate) SELECT :tenantId,:userId,'user',:userId2,'user.login',CONCAT(:displayName,' logged in to ',:tenantName),JSON_OBJECT('tenantId',:tenantId2,'role',:roleName),CURRENT_TIMESTAMP FROM tbl_activity_types at WHERE at.tenantId=:tenantId3 AND at.activityKey='user.login' AND at.isActive=1 LIMIT 1",
            "params": [
              {"name": ":tenantId", "value": "{{selectedAccess[0].tenantId}}"},
              {"name": ":userId", "value": "{{selectedAccess[0].userId}}"},
              {"name": ":userId2", "value": "{{selectedAccess[0].userId}}"},
              {"name": ":displayName", "value": "{{selectedAccess[0].displayName}}"},
              {"name": ":tenantName", "value": "{{selectedAccess[0].tenantName}}"},
              {"name": ":tenantId2", "value": "{{selectedAccess[0].tenantId}}"},
              {"name": ":roleName", "value": "{{selectedAccess[0].roleName}}"},
              {"name": ":tenantId3", "value": "{{selectedAccess[0].tenantId}}"}
            ]
          }
        },
        "output": true
      },
      {
        "module": "core",
        "action": "redirect",
        "options": {
          "url": "/",
          "status": 302
        }
      }
    ]
  }
}

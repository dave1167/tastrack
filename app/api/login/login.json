{
  "settings": {
    "options": {
      "nocsrf": true,
      "method": "post"
    }
  },
  "exec": {
    "steps": [
      {
        "name": "identity",
        "module": "auth",
        "action": "login",
        "options": {
          "provider": "security",
          "username": "{{$_POST.username}}",
          "password": "{{$_POST.password}}",
          "remember": "{{$_POST.remember}}"
        },
        "output": true,
        "meta": []
      },
      {
        "name": "userAccess",
        "module": "dbupdater",
        "action": "custom",
        "options": {
          "connection": "db",
          "sql": {
            "query": "SELECT utr.userId, utr.tenantId, utr.roleId, utr.isPrimary, u.fName, u.lName, u.displayName, t.tenantName, r.roleName, r.roleKey FROM tbl_user_tenant_roles utr INNER JOIN tbl_users u ON u.id = utr.userId INNER JOIN tbl_tenants t ON t.id = utr.tenantId INNER JOIN tbl_roles r ON r.id = utr.roleId WHERE utr.userId = :userId AND utr.status = 'active' ORDER BY utr.isPrimary DESC, utr.tenantId ASC, utr.roleId ASC LIMIT 1",
            "params": [
              {
                "name": ":userId",
                "value": "{{identity}}"
              }
            ]
          }
        },
        "output": true,
        "outputType": "array"
      },
      {
        "name": "user_id",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{identity}}"
        }
      },
      {
        "name": "tenant_id",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{userAccess[0].tenantId}}"
        }
      },
      {
        "name": "role_id",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{userAccess[0].roleId}}"
        }
      },
      {
        "name": "tenant_name",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{userAccess[0].tenantName}}"
        }
      },
      {
        "name": "fName",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{userAccess[0].fName}}"
        }
      },
      {
        "name": "lName",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{userAccess[0].lName}}"
        }
      },
      {
        "name": "displayName",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{userAccess[0].displayName}}"
        }
      },
      {
        "name": "role_name",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{userAccess[0].roleName}}"
        }
      },
      {
        "name": "role_key",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{userAccess[0].roleKey}}"
        }
      },
      {
        "module": "core",
        "action": "redirect",
        "options": {
          "url": "/",
          "status": 302
        }
      }
    ]
  }
}
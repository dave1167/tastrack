{
  "settings": {
    "options": {
      "nocsrf": true,
      "method": "post"
    }
  },
  "exec": {
    "steps": [
      {
        "name": "identity",
        "module": "auth",
        "action": "login",
        "options": {
          "provider": "security",
          "username": "{{$_POST.username}}",
          "password": "{{$_POST.password}}",
          "remember": "{{$_POST.remember}}"
        },
        "output": true,
        "meta": []
      },
      {
        "name": "userAccess",
        "module": "dbupdater",
        "action": "custom",
        "options": {
          "connection": "db",
          "sql": {
            "query": "SELECT utr.userId, utr.tenantId, utr.roleId, utr.isPrimary, u.fName, u.lName, u.displayName, t.tenantName, r.roleName, r.roleKey FROM tbl_user_tenant_roles utr INNER JOIN tbl_users u ON u.id = utr.userId INNER JOIN tbl_tenants t ON t.id = utr.tenantId INNER JOIN tbl_roles r ON r.id = utr.roleId WHERE utr.userId = :userId AND utr.isActive = 1 ORDER BY utr.isPrimary DESC, utr.tenantId ASC, utr.roleId ASC LIMIT 1",
            "params": [
              {
                "name": ":userId",
                "value": "{{identity}}"
              }
            ]
          }
        },
        "output": true,
        "outputType": "array",
        "collapsed": true,
        "meta": []
      },
      {
        "name": "loginRoute",
        "module": "dbupdater",
        "action": "custom",
        "options": {
          "connection": "db",
          "sql": {
            "query": "SELECT COUNT(DISTINCT utr.tenantId) AS tenantCount, CASE WHEN COUNT(DISTINCT utr.tenantId) = 0 THEN '/unauthorised' WHEN COUNT(DISTINCT utr.tenantId) > 1 THEN '/login/tenant' ELSE '/' END AS redirectUrl FROM tbl_user_tenant_roles utr WHERE utr.userId = :userId AND utr.isActive = 1",
            "params": [
              {
                "name": ":userId",
                "value": "{{identity}}"
              }
            ]
          }
        },
        "output": true,
        "outputType": "array",
        "meta": [],
        "collapsed": true
      },
      {
        "name": "USER_ID",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{identity}}"
        }
      },
      {
        "name": "TENANT_ID",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{userAccess[0].tenantId}}"
        }
      },
      {
        "name": "ROLE_ID",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{userAccess[0].roleId}}"
        }
      },
      {
        "name": "TENANT_NAME",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{userAccess[0].tenantName}}"
        }
      },
      {
        "name": "FNAME",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{userAccess[0].fName}}"
        }
      },
      {
        "name": "LNAME",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{userAccess[0].lName}}"
        }
      },
      {
        "name": "DISPLAY_NAME",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{userAccess[0].displayName}}"
        }
      },
      {
        "name": "ROLE_NAME",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{userAccess[0].roleName}}"
        }
      },
      {
        "name": "ROLE_KEY",
        "module": "core",
        "action": "setsession",
        "options": {
          "value": "{{userAccess[0].roleKey}}"
        }
      },
      {
        "name": "redirectAfterLogin",
        "module": "core",
        "action": "redirect",
        "options": {
          "url": "{{loginRoute[0].redirectUrl.default('/unauthorised')}}",
          "status": 302
        }
      }
    ]
  }
}
{
  "settings": {
    "options": {
      "method": "post"
    }
  },
  "meta": {
    "$_POST": [
      {
        "type": "number",
        "name": "contactCategoryId"
      },
      {
        "type": "text",
        "name": "organisationName"
      },
      {
        "type": "text",
        "name": "firstName"
      },
      {
        "type": "text",
        "name": "lastName"
      },
      {
        "type": "text",
        "name": "displayName",
        "options": {
          "rules": {
            "core:required": {
              "param": ""
            }
          }
        }
      },
      {
        "type": "text",
        "name": "email"
      },
      {
        "type": "text",
        "name": "phone"
      },
      {
        "type": "text",
        "name": "addressLine1"
      },
      {
        "type": "text",
        "name": "addressLine2"
      },
      {
        "type": "text",
        "name": "city"
      },
      {
        "type": "text",
        "name": "region"
      },
      {
        "type": "text",
        "name": "postcode"
      },
      {
        "type": "text",
        "name": "country"
      },
      {
        "type": "text",
        "name": "notes"
      },
      {
        "type": "number",
        "name": "isActive"
      }
    ]
  },
  "exec": {
    "steps": [
      {
        "name": "insertContact",
        "module": "dbupdater",
        "action": "custom",
        "options": {
          "connection": "db",
          "sql": {
            "query": "INSERT INTO tbl_contacts (tenantId,contactCategoryId,contactType,organisationName,firstName,lastName,displayName,email,phone,addressLine1,addressLine2,city,region,postcode,country,notes,isActive) VALUES (:tenantId,(SELECT c.contactCategoryId FROM tbl_contact_categories c WHERE c.contactCategoryId=:categoryId AND c.tenantId=:categoryTenantId AND c.active=1 LIMIT 1),(SELECT c.categoryName FROM tbl_contact_categories c WHERE c.contactCategoryId=:categoryId2 AND c.tenantId=:categoryTenantId2 AND c.active=1 LIMIT 1),:organisationName,:firstName,:lastName,:displayName,:email,:phone,:addressLine1,:addressLine2,:city,:region,:postcode,:country,:notes,:isActive)",
            "params": [
              {
                "name": ":tenantId",
                "value": "{{$_SESSION.TENANT_ID}}"
              },
              {
                "name": ":categoryId",
                "value": "{{$_POST.contactCategoryId}}"
              },
              {
                "name": ":categoryTenantId",
                "value": "{{$_SESSION.TENANT_ID}}"
              },
              {
                "name": ":categoryId2",
                "value": "{{$_POST.contactCategoryId}}"
              },
              {
                "name": ":categoryTenantId2",
                "value": "{{$_SESSION.TENANT_ID}}"
              },
              {
                "name": ":organisationName",
                "value": "{{$_POST.organisationName}}"
              },
              {
                "name": ":firstName",
                "value": "{{$_POST.firstName.lowercase().capitalize()}}"
              },
              {
                "name": ":lastName",
                "value": "{{$_POST.lastName.lowercase().capitalize()}}"
              },
              {
                "name": ":displayName",
                "value": "{{$_POST.displayName}}"
              },
              {
                "name": ":email",
                "value": "{{$_POST.email.lowercase()}}"
              },
              {
                "name": ":phone",
                "value": "{{$_POST.phone}}"
              },
              {
                "name": ":addressLine1",
                "value": "{{$_POST.addressLine1}}"
              },
              {
                "name": ":addressLine2",
                "value": "{{$_POST.addressLine2}}"
              },
              {
                "name": ":city",
                "value": "{{$_POST.city}}"
              },
              {
                "name": ":region",
                "value": "{{$_POST.region}}"
              },
              {
                "name": ":postcode",
                "value": "{{$_POST.postcode}}"
              },
              {
                "name": ":country",
                "value": "{{$_POST.country}}"
              },
              {
                "name": ":notes",
                "value": "{{$_POST.notes}}"
              },
              {
                "name": ":isActive",
                "value": "{{$_POST.isActive.default(1)}}"
              }
            ]
          }
        },
        "output": true
      },
      {
        "name": "logContactCreated",
        "module": "dbupdater",
        "action": "custom",
        "options": {
          "connection": "db",
          "sql": {
            "query": "INSERT INTO tbl_activity_log (tenantId,userId,entityType,entityId,actionType,summary,afterJson,createdDate) SELECT :tenantId,:userId,'contact',:contactId,'contact.created',CONCAT(:actor,' created contact ',:contactName),JSON_OBJECT('displayName',:contactName2,'email',:email,'phone',:phone,'categoryId',:categoryId),CURRENT_TIMESTAMP FROM tbl_activity_types at WHERE at.tenantId=:tenantId2 AND at.activityKey='contact.created' AND at.isActive=1 LIMIT 1",
            "params": [
              {
                "name": ":tenantId",
                "value": "{{$_SESSION.TENANT_ID}}"
              },
              {
                "name": ":userId",
                "value": "{{$_SESSION.USER_ID}}"
              },
              {
                "name": ":contactId",
                "value": "{{insertContact.insertId}}"
              },
              {
                "name": ":actor",
                "value": "{{$_SESSION.DISPLAY_NAME.default('A user')}}"
              },
              {
                "name": ":contactName",
                "value": "{{$_POST.displayName}}"
              },
              {
                "name": ":contactName2",
                "value": "{{$_POST.displayName}}"
              },
              {
                "name": ":email",
                "value": "{{$_POST.email.default('').lowercase()}}"
              },
              {
                "name": ":phone",
                "value": "{{$_POST.phone.default('')}}"
              },
              {
                "name": ":categoryId",
                "value": "{{$_POST.contactCategoryId}}"
              },
              {
                "name": ":tenantId2",
                "value": "{{$_SESSION.TENANT_ID}}"
              }
            ]
          }
        },
        "output": true
      },
      {
        "module": "core",
        "action": "redirect",
        "options": {
          "url": "/contacts",
          "status": 302
        }
      }
    ]
  }
}

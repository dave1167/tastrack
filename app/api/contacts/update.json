{
  "settings": {
    "options": {
      "method": "post"
    }
  },
  "meta": {
    "$_POST": [
      {
        "type": "number",
        "name": "id"
      },
      {
        "type": "number",
        "name": "contactCategoryId"
      },
      {
        "type": "text",
        "name": "organisationName"
      },
      {
        "type": "text",
        "name": "firstName"
      },
      {
        "type": "text",
        "name": "lastName"
      },
      {
        "type": "text",
        "name": "displayName"
      },
      {
        "type": "text",
        "name": "email"
      },
      {
        "type": "text",
        "name": "phone"
      },
      {
        "type": "text",
        "name": "addressLine1"
      },
      {
        "type": "text",
        "name": "addressLine2"
      },
      {
        "type": "text",
        "name": "city"
      },
      {
        "type": "text",
        "name": "region"
      },
      {
        "type": "text",
        "name": "postcode"
      },
      {
        "type": "text",
        "name": "country"
      },
      {
        "type": "text",
        "name": "notes"
      },
      {
        "type": "number",
        "name": "isActive"
      }
    ]
  },
  "exec": {
    "steps": [
      {
        "name": "contactBeforeChange",
        "module": "dbupdater",
        "action": "custom",
        "options": {
          "connection": "db",
          "sql": {
            "query": "SELECT id,displayName,email,phone,contactCategoryId,isActive FROM tbl_contacts WHERE id=:id AND tenantId=:tenantId LIMIT 1",
            "params": [
              {
                "name": ":id",
                "value": "{{$_POST.id}}"
              },
              {
                "name": ":tenantId",
                "value": "{{$_SESSION.TENANT_ID}}"
              }
            ]
          }
        },
        "output": true,
        "outputType": "array"
      },
      {
        "name": "updateContact",
        "module": "dbupdater",
        "action": "custom",
        "options": {
          "connection": "db",
          "sql": {
            "query": "UPDATE tbl_contacts SET contactCategoryId=(SELECT c.contactCategoryId FROM tbl_contact_categories c WHERE c.contactCategoryId=:categoryId AND c.tenantId=:categoryTenantId LIMIT 1),contactType=(SELECT c.categoryName FROM tbl_contact_categories c WHERE c.contactCategoryId=:categoryId2 AND c.tenantId=:categoryTenantId2 LIMIT 1),organisationName=:organisationName,firstName=:firstName,lastName=:lastName,displayName=:displayName,email=:email,phone=:phone,addressLine1=:addressLine1,addressLine2=:addressLine2,city=:city,region=:region,postcode=:postcode,country=:country,notes=:notes,isActive=:isActive,modifiedDate=CURRENT_TIMESTAMP WHERE id=:id AND tenantId=:tenantId",
            "params": [
              {
                "name": ":categoryId",
                "value": "{{$_POST.contactCategoryId}}"
              },
              {
                "name": ":categoryTenantId",
                "value": "{{$_SESSION.TENANT_ID}}"
              },
              {
                "name": ":categoryId2",
                "value": "{{$_POST.contactCategoryId}}"
              },
              {
                "name": ":categoryTenantId2",
                "value": "{{$_SESSION.TENANT_ID}}"
              },
              {
                "name": ":organisationName",
                "value": "{{$_POST.organisationName}}"
              },
        {
          "name": ":firstName",
          "value": "{{$_POST.firstName.lowercase().capitalize()}}"
        },
        {
          "name": ":lastName",
          "value": "{{$_POST.lastName.lowercase().capitalize()}}"
              },
              {
                "name": ":displayName",
                "value": "{{$_POST.displayName}}"
              },
        {
          "name": ":email",
          "value": "{{$_POST.email.lowercase()}}"
              },
              {
                "name": ":phone",
                "value": "{{$_POST.phone}}"
              },
              {
                "name": ":addressLine1",
                "value": "{{$_POST.addressLine1}}"
              },
              {
                "name": ":addressLine2",
                "value": "{{$_POST.addressLine2}}"
              },
              {
                "name": ":city",
                "value": "{{$_POST.city}}"
              },
              {
                "name": ":region",
                "value": "{{$_POST.region}}"
              },
              {
                "name": ":postcode",
                "value": "{{$_POST.postcode}}"
              },
              {
                "name": ":country",
                "value": "{{$_POST.country}}"
              },
              {
                "name": ":notes",
                "value": "{{$_POST.notes}}"
              },
              {
                "name": ":isActive",
                "value": "{{$_POST.isActive.default(1)}}"
              },
              {
                "name": ":id",
                "value": "{{$_POST.id}}"
              },
              {
                "name": ":tenantId",
                "value": "{{$_SESSION.TENANT_ID}}"
              }
            ]
          }
        },
        "output": true
      },
      {
        "name": "logContactUpdated",
        "module": "dbupdater",
        "action": "custom",
        "options": {
          "connection": "db",
          "sql": {
            "query": "INSERT INTO tbl_activity_log (tenantId,userId,entityType,entityId,actionType,summary,beforeJson,afterJson,createdDate) SELECT :tenantId,:userId,'contact',:contactId,'contact.updated',CONCAT(:actor,' updated contact ',:contactName),JSON_OBJECT('displayName',:oldName,'email',:oldEmail,'phone',:oldPhone,'categoryId',:oldCategory,'isActive',:oldActive),JSON_OBJECT('displayName',:newName,'email',:newEmail,'phone',:newPhone,'categoryId',:newCategory,'isActive',:newActive),CURRENT_TIMESTAMP FROM tbl_activity_types at WHERE at.tenantId=:tenantId2 AND at.activityKey='contact.updated' AND at.isActive=1 LIMIT 1",
            "params": [
              {
                "name": ":tenantId",
                "value": "{{$_SESSION.TENANT_ID}}"
              },
              {
                "name": ":userId",
                "value": "{{$_SESSION.USER_ID}}"
              },
              {
                "name": ":contactId",
                "value": "{{$_POST.id}}"
              },
              {
                "name": ":actor",
                "value": "{{$_SESSION.DISPLAY_NAME.default('A user')}}"
              },
              {
                "name": ":contactName",
                "value": "{{$_POST.displayName}}"
              },
              {
                "name": ":oldName",
                "value": "{{contactBeforeChange[0].displayName}}"
              },
              {
                "name": ":oldEmail",
                "value": "{{contactBeforeChange[0].email}}"
              },
              {
                "name": ":oldPhone",
                "value": "{{contactBeforeChange[0].phone}}"
              },
              {
                "name": ":oldCategory",
                "value": "{{contactBeforeChange[0].contactCategoryId}}"
              },
              {
                "name": ":oldActive",
                "value": "{{contactBeforeChange[0].isActive}}"
              },
              {
                "name": ":newName",
                "value": "{{$_POST.displayName}}"
              },
              {
                "name": ":newEmail",
                "value": "{{$_POST.email.default('').lowercase()}}"
              },
              {
                "name": ":newPhone",
                "value": "{{$_POST.phone.default('')}}"
              },
              {
                "name": ":newCategory",
                "value": "{{$_POST.contactCategoryId}}"
              },
              {
                "name": ":newActive",
                "value": "{{$_POST.isActive.default(1)}}"
              },
              {
                "name": ":tenantId2",
                "value": "{{$_SESSION.TENANT_ID}}"
              }
            ]
          }
        },
        "output": true
      },
      {
        "module": "core",
        "action": "redirect",
        "options": {
          "url": "/contacts",
          "status": 302
        }
      }
    ]
  }
}

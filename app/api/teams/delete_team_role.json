{
  "settings": {
    "options": {
      "nocsrf": true,
      "method": "post"
    }
  },
  "meta": {
    "$_POST": [
      {
        "type": "number",
        "fieldName": "roleId",
        "options": {
          "rules": {
            "core:required": {
              "param": ""
            }
          }
        },
        "name": "roleId"
      }
    ],
    "$_SESSION": [
      {
        "type": "number",
        "name": "TENANT_ID"
      }
    ]
  },
  "exec": {
    "steps": [
      {
        "name": "qryRoleUsage",
        "module": "dbupdater",
        "action": "custom",
        "options": {
          "connection": "db",
          "sql": {
            "query": "SELECT COUNT(*) AS userCount FROM tbl_team_members tm INNER JOIN tbl_team_roles tr ON tr.tenantId = tm.tenantId AND tr.teamId = tm.teamId AND tr.id = tm.teamRole WHERE tr.id = :roleId AND tr.tenantId = :tenantId",
            "params": [
              {
                "name": ":roleId",
                "value": "{{$_POST.roleId}}"
              },
              {
                "name": ":tenantId",
                "value": "{{$_SESSION.TENANT_ID}}"
              }
            ]
          }
        },
        "output": true,
        "meta": [
          {
            "name": "userCount",
            "type": "number"
          }
        ],
        "outputType": "array",
        "collapsed": true
      },
      {
        "name": "checkRoleUsage",
        "module": "core",
        "action": "condition",
        "options": {
          "if": "{{qryRoleUsage[0].userCount > 0}}",
          "then": {
            "steps": [
              {
                "name": "errRoleInUse",
                "module": "core",
                "action": "error",
                "options": {
                  "message": "This team role cannot be deleted because one or more users are still assigned to it. Move those users to another role first."
                }
              }
            ]
          },
          "else": {
            "steps": []
          }
        },
        "outputType": "boolean",
        "collapsed": true
      },
      {
        "name": "deleteTeamRole",
        "module": "dbupdater",
        "action": "custom",
        "options": {
          "connection": "db",
          "sql": {
            "query": "DELETE FROM tbl_team_roles WHERE id = :roleId AND tenantId = :tenantId",
            "params": [
              {
                "name": ":roleId",
                "value": "{{$_POST.roleId}}"
              },
              {
                "name": ":tenantId",
                "value": "{{$_SESSION.TENANT_ID}}"
              }
            ]
          }
        },
        "output": true,
        "meta": [],
        "outputType": "array",
        "collapsed": true
      }
    ]
  }
}
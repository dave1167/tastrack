{
  "settings": {
    "options": {
      "method": "post"
    }
  },
  "meta": {
    "options": {
      "linkedFile": "/views/teams/create_team.ejs",
      "linkedForm": "frmCreateTeam"
    },
    "$_POST": [
      {
        "type": "text",
        "fieldName": "teamName",
        "options": {
          "rules": {
            "core:required": {
              "param": ""
            }
          }
        },
        "name": "teamName"
      },
      {
        "type": "text",
        "fieldName": "description",
        "name": "description"
      },
      {
        "type": "number",
        "fieldName": "isActive",
        "options": {
          "rules": {
            "core:required": {
              "param": ""
            }
          }
        },
        "name": "isActive"
      }
    ]
  },
  "exec": {
    "steps": [
      {
        "name": "insertTeam",
        "module": "dbupdater",
        "action": "custom",
        "options": {
          "connection": "db",
          "sql": {
            "query": "INSERT INTO tbl_teams (tenantId, teamName, description, isActive) VALUES (:tenantId, :teamName, :description, :isActive)",
            "params": [
              {
                "name": ":tenantId",
                "value": "{{$_SESSION.TENANT_ID}}",
                "recid": 1
              },
              {
                "name": ":teamName",
                "value": "{{$_POST.teamName}}",
                "recid": 2
              },
              {
                "name": ":description",
                "value": "{{$_POST.description}}",
                "recid": 3
              },
              {
                "name": ":isActive",
                "value": "{{$_POST.isActive.default(1)}}",
                "recid": 4
              }
            ]
          }
        },
        "output": true,
        "meta": [],
        "outputType": "array",
        "collapsed": true
      },
      {
        "module": "core",
        "action": "redirect",
        "options": {
          "url": "/teams/teams",
          "status": 302
        }
      }
    ]
  }
}
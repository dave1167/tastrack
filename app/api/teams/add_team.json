{
  "settings": {
    "options": {
      "method": "post"
    }
  },
  "meta": {
    "$_POST": [
      {
        "type": "text",
        "name": "teamName"
      },
      {
        "type": "text",
        "name": "description"
      },
      {
        "type": "number",
        "name": "isActive"
      }
    ]
  },
  "exec": {
    "steps": [
      {
        "name": "insertTeam",
        "module": "dbupdater",
        "action": "custom",
        "options": {
          "connection": "db",
          "sql": {
            "query": "INSERT INTO tbl_teams (tenantId, teamName, description, isActive) VALUES (:tenantId, :teamName, :description, :isActive)",
            "params": [
              {
                "name": ":tenantId",
                "value": "{{$_SESSION.TENANT_ID}}"
              },
              {
                "name": ":teamName",
                "value": "{{$_POST.teamName}}"
              },
              {
                "name": ":description",
                "value": "{{$_POST.description}}"
              },
              {
                "name": ":isActive",
                "value": "{{$_POST.isActive.default(1)}}"
              }
            ]
          }
        },
        "output": true
      },
      {
        "module": "core",
        "action": "redirect",
        "options": {
          "url": "/teams/teams",
          "status": 302
        }
      }
    ]
  }
}

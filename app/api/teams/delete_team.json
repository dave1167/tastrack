{
  "settings": {
    "options": {
      "method": "post"
    }
  },
  "meta": {
    "$_GET": [
      {
        "type": "number",
        "name": "id"
      }
    ]
  },
  "exec": {
    "steps": [
      {
        "name": "deleteTeam",
        "module": "dbupdater",
        "action": "custom",
        "options": {
          "connection": "db",
          "sql": {
            "query": "UPDATE tbl_teams SET isActive = 0 WHERE id = :id AND tenantId = :tenantId",
            "params": [
              {
                "name": ":id",
                "value": "{{$_GET.id}}"
              },
              {
                "name": ":tenantId",
                "value": "{{$_SESSION.TENANT_ID}}"
              }
            ]
          }
        },
        "output": true
      },
      {
        "module": "core",
        "action": "redirect",
        "options": {
          "url": "/teams/teams",
          "status": 302
        }
      }
    ]
  }
}

{
  "routes": [
    {
      "path": "/",
      "page": "dashboard/dashboard",
      "layout": "main_shell",
      "routeType": "page",
      "restrict": {
        "provider": "security",
        "permissions": [
          "owner-admin"
        ],
        "loginUrl": "/login/login",
        "forbiddenUrl": "/unauthorised"
      }
    },
    {
      "path": "/login",
      "page": "login/login",
      "layout": "main",
      "routeType": "page"
    },
    {
      "path": "/login/login",
      "page": "login/login",
      "layout": "main",
      "routeType": "page"
    },
    {
      "path": "/unauthorised",
      "page": "unauthorised",
      "layout": "main",
      "routeType": "page"
    },
    {
      "path": "/dashboard/dashboard",
      "page": "dashboard/dashboard",
      "layout": "main_shell",
      "routeType": "page"
    },
    {
      "path": "/login/tenant",
      "page": "login/tenant",
      "layout": "main",
      "routeType": "page"
    }
  ],
  "layouts": {
    "main_shell": {}
  }
}
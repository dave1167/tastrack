<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="template_tasks" appConnect="local" components="{dmxStateManagement:{}}" -->
<dmx-serverconnect id="scTemplate" url="/api/templates/get" dmx-param:id="query.templateId"></dmx-serverconnect>
<dmx-serverconnect id="scTasks" url="/api/workflow_templates/list_tasks" dmx-param:templateid="query.templateId" dmx-param:stageid="query.stageId"></dmx-serverconnect>

<div class="row g-4">
    <div class="col-12"><div class="d-flex justify-content-between align-items-center gap-3"><div><h1 class="mb-1">Template Tasks</h1><p class="text-muted mb-0"><span dmx-text="scTemplate.data.query[0].templateName"></span><span dmx-show="scTasks.data.query.count()"> · </span><span dmx-text="scTasks.data.query[0].stageName"></span></p></div><a class="btn btn-outline-secondary" dmx-bind:href="'/workflow_templates/template_stages?id=' + query.templateId">Back to stages</a></div></div>

    <div class="col-12 col-xl-4"><div class="card border-0 shadow-sm"><div class="card-header bg-white"><h2 class="h5 mb-0">Add task</h2></div><div class="card-body">
        <form method="post" action="/api/workflow_templates/create_task"><%- _csrfInput() %>
            <input type="hidden" name="templateId" dmx-bind:value="query.templateId"><input type="hidden" name="templateStageId" dmx-bind:value="query.stageId">
            <div class="mb-3"><label class="form-label">Task name</label><input class="form-control" name="taskName" required></div>
            <div class="mb-3"><label class="form-label">Description</label><textarea class="form-control" name="description" rows="3"></textarea></div>
            <div class="row g-3"><div class="col-6"><label class="form-label">Priority</label><select class="form-select" name="priority"><option value="low">Low</option><option value="normal" selected>Normal</option><option value="high">High</option><option value="urgent">Urgent</option></select></div><div class="col-6"><label class="form-label">Required</label><select class="form-select" name="isRequired"><option value="1" selected>Yes</option><option value="0">No</option></select></div>
            <div class="col-12"><label class="form-label">Due from</label><select class="form-select" name="dueOffsetType"><option value="">No automatic due date</option><option value="workflow_creation_date">Workflow creation</option><option value="workflow_start_date">Workflow start</option><option value="event_target_date">Target date</option><option value="stage_start_date">Stage start</option></select></div><div class="col-6"><label class="form-label">Days</label><input class="form-control" name="dueOffsetDays" type="number" value="0"></div><div class="col-6"><label class="form-label">Relation</label><select class="form-select" name="dueRelation"><option value="after">After</option><option value="before">Before</option><option value="same_day">Same day</option></select></div><div class="col-12"><label class="form-label">Default owner</label><select class="form-select" name="defaultOwnerType"><option value="unassigned">Unassigned</option><option value="workflow_owner">Workflow owner</option></select></div></div>
            <button class="btn btn-primary mt-4" type="submit">Add Task</button>
        </form>
    </div></div></div>

    <div class="col-12 col-xl-8"><div class="d-flex justify-content-between mb-3"><h2 class="h5 mb-0">Tasks in this stage</h2><span class="badge rounded-pill bg-primary" dmx-text="scTasks.data.query.count() + (scTasks.data.query.count() == 1 ? ' task' : ' tasks')"></span></div>
        <div is="dmx-repeat" id="repTasks" dmx-bind:repeat="scTasks.data.query">
            <div class="card border-0 shadow-sm mb-3"><div class="card-body"><form method="post" action="/api/workflow_templates/update_task"><%- _csrfInput() %>
                <input type="hidden" name="id" dmx-bind:value="$value.id"><input type="hidden" name="templateId" dmx-bind:value="$value.templateId"><input type="hidden" name="templateStageId" dmx-bind:value="$value.templateStageId">
                <div class="row g-3"><div class="col-md-2"><label class="form-label">Order</label><input class="form-control" name="sortOrder" type="number" min="1" dmx-bind:value="$value.sortOrder"></div><div class="col-md-7"><label class="form-label">Task</label><input class="form-control" name="taskName" required dmx-bind:value="$value.taskName"></div><div class="col-md-3"><label class="form-label">Status</label><select class="form-select" name="status" dmx-bind:value="$value.status"><option value="active">Active</option><option value="inactive">Inactive</option><option value="archived">Archived</option></select></div>
                <div class="col-12"><label class="form-label">Description</label><textarea class="form-control" name="description" rows="2" dmx-bind:value="$value.description"></textarea></div><div class="col-md-3"><label class="form-label">Priority</label><select class="form-select" name="priority" dmx-bind:value="$value.priority"><option value="low">Low</option><option value="normal">Normal</option><option value="high">High</option><option value="urgent">Urgent</option></select></div><div class="col-md-3"><label class="form-label">Required</label><select class="form-select" name="isRequired" dmx-bind:value="$value.isRequired"><option value="1">Yes</option><option value="0">No</option></select></div><div class="col-md-3"><label class="form-label">Due from</label><select class="form-select" name="dueOffsetType" dmx-bind:value="$value.dueOffsetType"><option value="">None</option><option value="workflow_creation_date">Creation</option><option value="workflow_start_date">Start</option><option value="event_target_date">Target</option><option value="stage_start_date">Stage start</option></select></div><div class="col-md-3"><label class="form-label">Days</label><input class="form-control" name="dueOffsetDays" type="number" dmx-bind:value="$value.dueOffsetDays"></div>
                <input type="hidden" name="dueRelation" dmx-bind:value="$value.dueRelation"><input type="hidden" name="defaultOwnerType" dmx-bind:value="$value.defaultOwnerType"><div class="col-12 text-end"><button class="btn btn-sm btn-outline-primary" type="submit">Save task</button></div></div>
            </form></div></div>
        </div>
        <div class="text-muted" dmx-show="!scTasks.state.executing && scTasks.data.query.count() == 0">No tasks in this stage yet.</div>
    </div>
</div>
<meta name="ac:route" content="/workflow_templates/template_tasks">

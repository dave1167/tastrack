<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="template_task_dependencies" appConnect="local" components="{dmxStateManagement:{}}" -->
<dmx-serverconnect id="scTemplate" url="/api/templates/get" dmx-param:id="query.templateId"></dmx-serverconnect>
<dmx-serverconnect id="scTaskOptions" url="/api/workflow_templates/task_options" dmx-param:templateid="query.templateId"></dmx-serverconnect>
<dmx-serverconnect id="scDependencies" url="/api/workflow_templates/list_dependencies" dmx-param:templateid="query.templateId"></dmx-serverconnect>

<div class="row g-4">
    <div class="col-12"><div class="d-flex justify-content-between align-items-center gap-3"><div><h1 class="mb-1">Task Dependencies</h1><p class="text-muted mb-0" dmx-text="scTemplate.data.query[0].templateName"></p></div><a class="btn btn-outline-secondary" dmx-bind:href="'/workflow_templates/template_stages?id=' + query.templateId">Back to stages</a></div></div>
    <div class="col-12 col-xl-5"><div class="card border-0 shadow-sm"><div class="card-header bg-white"><h2 class="h5 mb-0">Add dependency</h2></div><div class="card-body"><p class="text-muted small">Choose the blocked task and the task it depends on.</p><form method="post" action="/api/workflow_templates/create_dependency"><%- _csrfInput() %><input type="hidden" name="templateId" dmx-bind:value="query.templateId"><div class="mb-3"><label class="form-label">Task</label><select class="form-select" name="templateTaskId" required dmx-bind:options="scTaskOptions.data.query" optiontext="taskLabel" optionvalue="id"><option value="">Select task</option></select></div><div class="mb-3"><label class="form-label">Depends on</label><select class="form-select" name="dependsOnTemplateTaskId" required dmx-bind:options="scTaskOptions.data.query" optiontext="taskLabel" optionvalue="id"><option value="">Select prerequisite</option></select></div><div class="mb-4"><label class="form-label">Type</label><select class="form-select" name="dependencyType"><option value="finish_to_start">Finish to start</option><option value="start_to_start">Start to start</option><option value="finish_to_finish">Finish to finish</option><option value="blocking">Blocking</option></select></div><button class="btn btn-primary" type="submit">Add Dependency</button></form></div></div></div>
    <div class="col-12 col-xl-7"><div class="card border-0 shadow-sm"><div class="card-header bg-white d-flex justify-content-between"><h2 class="h5 mb-0">Existing dependencies</h2><span class="badge rounded-pill bg-primary" dmx-text="scDependencies.data.query.count()"></span></div><div class="card-body"><div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead><tr><th>Task</th><th>Depends on</th><th>Type</th><th></th></tr></thead><tbody is="dmx-repeat" dmx-bind:repeat="scDependencies.data.query"><tr><td><strong dmx-text="taskName"></strong><div class="small text-muted" dmx-text="stageName"></div></td><td><strong dmx-text="dependsOnTaskName"></strong><div class="small text-muted" dmx-text="dependsOnStageName"></div></td><td dmx-text="dependencyType"></td><td class="text-end"><form method="post" action="/api/workflow_templates/delete_dependency"><%- _csrfInput() %><input type="hidden" name="id" dmx-bind:value="id"><input type="hidden" name="templateId" dmx-bind:value="templateId"><button class="btn btn-sm btn-outline-danger" type="submit"><i class="fas fa-trash"></i></button></form></td></tr></tbody></table></div><p class="text-muted small mt-3 mb-0" dmx-show="!scDependencies.state.executing && scDependencies.data.query.count() == 0">No dependencies added yet.</p></div></div></div>
</div>
<meta name="ac:route" content="/workflow_templates/template_task_dependencies">

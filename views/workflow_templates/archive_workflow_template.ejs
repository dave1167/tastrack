<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="archive_workflow_template" appConnect="local" -->
<dmx-serverconnect id="scTemplate" url="/api/templates/get" dmx-param:id="query.id"></dmx-serverconnect>
<div class="row g-4"><div class="col-12"><h1 class="mb-1">Archive Workflow Template</h1><p class="text-muted">Review the template before continuing.</p></div><div class="col-12 col-xl-6"><div class="card border-0 shadow-sm"><div class="card-header bg-white"><h2 class="h5 mb-0">Confirm archive</h2></div><div class="card-body"><div class="alert alert-warning">Archived templates remain available for historic workflows but cannot be used as the default.</div><dl class="row"><dt class="col-sm-4">Template</dt><dd class="col-sm-8" dmx-text="scTemplate.data.query[0].templateName"></dd><dt class="col-sm-4">Version</dt><dd class="col-sm-8" dmx-text="scTemplate.data.query[0].versionNumber"></dd></dl><form method="post" dmx-bind:action="'/api/templates/archive?id=' + query.id"><%- _csrfInput() %><div class="d-flex gap-2"><button class="btn btn-danger" type="submit">Archive Template</button><a class="btn btn-light" href="/templates">Cancel</a></div></form></div></div></div></div><meta name="ac:route" content="/templates/archive">

<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="edit_workflow_template" appConnect="local" -->
<dmx-serverconnect id="scTemplate" url="/api/templates/get" dmx-param:id="query.id"></dmx-serverconnect>
<div class="row g-4"><div class="col-12"><div class="d-flex justify-content-between align-items-center"><div><h1 class="mb-1">Edit Workflow Template</h1><p class="text-muted mb-0">Update template identity, version and publication status.</p></div><a class="btn btn-outline-secondary" href="/templates">Back to templates</a></div></div><div class="col-12 col-xl-7"><div class="card border-0 shadow-sm"><div class="card-header bg-white"><h2 class="h5 mb-0">Template details</h2></div><div class="card-body"><form method="post" action="/api/templates/update"><%- _csrfInput() %><input type="hidden" name="id" dmx-bind:value="scTemplate.data.query[0].id"><div class="mb-3"><label class="form-label">Template name</label><input class="form-control" name="templateName" required dmx-bind:value="scTemplate.data.query[0].templateName"></div><div class="mb-3"><label class="form-label">Template key</label><input class="form-control" name="templateKey" dmx-bind:value="scTemplate.data.query[0].templateKey"></div><div class="mb-3"><label class="form-label">Description</label><textarea class="form-control" name="description" rows="4" dmx-bind:value="scTemplate.data.query[0].description"></textarea></div><div class="row g-3"><div class="col-md-4"><label class="form-label">Version</label><input class="form-control" name="versionNumber" type="number" min="1" dmx-bind:value="scTemplate.data.query[0].versionNumber"></div><div class="col-md-4"><label class="form-label">Status</label><select class="form-select" name="status" dmx-bind:value="scTemplate.data.query[0].status"><option value="draft">Draft</option><option value="published">Published</option><option value="inactive">Inactive</option><option value="archived">Archived</option></select></div><div class="col-md-4"><label class="form-label">Default</label><select class="form-select" name="isDefault" dmx-bind:value="scTemplate.data.query[0].isDefault"><option value="0">No</option><option value="1">Yes</option></select></div></div><div class="d-flex gap-2 mt-4"><button class="btn btn-primary" type="submit">Update Template</button><a class="btn btn-light" href="/templates">Cancel</a></div></form></div></div></div></div><meta name="ac:route" content="/templates/edit">

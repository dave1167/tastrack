<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="edit_configuration" appConnect="local" -->
<dmx-serverconnect id="scConfiguration" url="/api/locations/getConfiguration" dmx-param:id="query.id"></dmx-serverconnect>
<div class="row g-4"><div class="col-12"><div class="d-flex justify-content-between align-items-center"><div><h1 class="mb-1">Edit configuration</h1><p class="text-muted mb-0"><span dmx-text="scConfiguration.data.query[0].locationName"></span> · <span dmx-text="scConfiguration.data.query[0].spaceName"></span></p></div><a class="btn btn-outline-secondary" dmx-bind:href="'/locations/view?id=' + scConfiguration.data.query[0].locationId">Cancel</a></div></div><div class="col-12 col-xl-8"><div class="card border-0 shadow-sm"><div class="card-body"><form method="post" action="/api/locations/updateConfiguration"><%- _csrfInput() %><input type="hidden" name="id" dmx-bind:value="scConfiguration.data.query[0].id"><input type="hidden" name="spaceId" dmx-bind:value="scConfiguration.data.query[0].spaceId"><input type="hidden" name="locationId" dmx-bind:value="scConfiguration.data.query[0].locationId"><div class="mb-3"><label class="form-label">Configuration name</label><input class="form-control" name="configurationName" required dmx-bind:value="scConfiguration.data.query[0].configurationName"></div><div class="row g-3"><div class="col-md-3"><label class="form-label">Seated</label><input class="form-control" name="seatedCapacity" type="number" min="0" dmx-bind:value="scConfiguration.data.query[0].seatedCapacity"></div><div class="col-md-3"><label class="form-label">Standing</label><input class="form-control" name="standingCapacity" type="number" min="0" dmx-bind:value="scConfiguration.data.query[0].standingCapacity"></div><div class="col-md-3"><label class="form-label">Maximum</label><input class="form-control" name="maximumTotalCapacity" type="number" min="0" dmx-bind:value="scConfiguration.data.query[0].maximumTotalCapacity"></div><div class="col-md-3"><label class="form-label">Default</label><select class="form-select" name="isDefault" dmx-bind:value="scConfiguration.data.query[0].isDefault"><option value="0">No</option><option value="1">Yes</option></select></div><div class="col-md-3"><label class="form-label">Status</label><select class="form-select" name="isActive" dmx-bind:value="scConfiguration.data.query[0].isActive"><option value="1">Active</option><option value="0">Inactive</option></select></div><div class="col-12"><label class="form-label">Description</label><textarea class="form-control" name="description" rows="4" dmx-bind:value="scConfiguration.data.query[0].description"></textarea></div></div><div class="mt-4"><button class="btn btn-primary" type="submit">Save changes</button></div></form></div></div></div></div>
<meta name="ac:route" content="/locations/edit_configuration">

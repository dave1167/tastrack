<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="view_location" appConnect="local" components="{dmxStateManagement:{}}" -->
<dmx-serverconnect id="scLocationDetail" url="/api/locations/detail" dmx-param:id="query.id"></dmx-serverconnect>
<div class="row g-4">
    <div class="col-12"><div class="d-flex justify-content-between align-items-center gap-3"><div><h1 class="mb-1" dmx-text="scLocationDetail.data.location[0].locationName"></h1><p class="text-muted mb-0"><span dmx-text="scLocationDetail.data.location[0].townCity"></span><span dmx-show="scLocationDetail.data.location[0].postcode"> · </span><span dmx-text="scLocationDetail.data.location[0].postcode"></span></p></div><div class="d-flex gap-2"><a class="btn btn-outline-secondary" href="/locations">Back</a><a class="btn btn-primary" dmx-bind:href="'/locations/edit?id=' + query.id"><i class="fas fa-pen me-2"></i>Edit location</a></div></div></div>
    <div class="col-12"><div class="card border-0 shadow-sm"><div class="card-body"><div class="row g-3"><div class="col-md-3"><div class="small text-muted">Type</div><div dmx-text="scLocationDetail.data.location[0].locationType || '—'"></div></div><div class="col-md-6"><div class="small text-muted">Address</div><div><span dmx-text="scLocationDetail.data.location[0].addressLine1"></span><span dmx-show="scLocationDetail.data.location[0].townCity">, </span><span dmx-text="scLocationDetail.data.location[0].townCity"></span><span dmx-show="scLocationDetail.data.location[0].postcode"> </span><span dmx-text="scLocationDetail.data.location[0].postcode"></span></div></div><div class="col-md-3"><div class="small text-muted">Contact</div><div dmx-text="scLocationDetail.data.location[0].telephone || scLocationDetail.data.location[0].email || '—'"></div></div></div></div></div></div>
    <div class="col-12"><div class="d-flex justify-content-between align-items-center"><h2 class="h4 mb-0" dmx-text="scTerminology.data.query[0].spacePlural">Spaces</h2><a class="btn btn-sm btn-outline-primary" dmx-bind:href="'/locations/add_space?locationid=' + query.id">Add space</a></div></div>
    <div class="col-12" is="dmx-repeat" dmx-bind:repeat="scLocationDetail.data.spaces"><div class="card border-0 shadow-sm mb-3"><div class="card-header bg-white d-flex justify-content-between align-items-center"><div><h3 class="h5 mb-1" dmx-text="$value.spaceName"></h3><div class="small text-muted"><span dmx-text="$value.spaceType || 'No type'"></span><span> · </span><span dmx-text="$value.defaultCapacity ? $value.defaultCapacity + ' capacity' : 'Capacity not set'"></span></div></div><a class="btn btn-sm btn-outline-primary" dmx-bind:href="'/locations/edit_space?id=' + $value.id + '&locationid=' + query.id">Edit space</a></div><div class="card-body"><div class="d-flex justify-content-between align-items-center mb-3"><h4 class="h6 text-uppercase text-muted mb-0" dmx-text="scTerminology.data.query[0].configurationPlural">Configurations</h4><a class="btn btn-sm btn-outline-secondary" dmx-bind:href="'/locations/add_configuration?spaceid=' + $value.id + '&locationid=' + query.id">Add configuration</a></div><div class="table-responsive"><table class="table table-sm align-middle mb-0"><thead><tr><th>Name</th><th>Seated</th><th>Standing</th><th>Maximum</th><th>Default</th><th>Status</th><th></th></tr></thead><tbody is="dmx-repeat" dmx-bind:repeat="scLocationDetail.data.configurations.where('spaceId',$value.id)"><tr><td class="fw-semibold" dmx-text="$value.configurationName"></td><td dmx-text="$value.seatedCapacity || '—'"></td><td dmx-text="$value.standingCapacity || '—'"></td><td dmx-text="$value.maximumTotalCapacity || '—'"></td><td><i class="fas fa-check text-success" dmx-show="$value.isDefault == 1"></i></td><td><span class="badge bg-success" dmx-show="$value.isActive == 1">Active</span><span class="badge bg-secondary" dmx-show="$value.isActive != 1">Inactive</span></td><td class="text-end"><a class="btn btn-sm btn-outline-primary" dmx-bind:href="'/locations/edit_configuration?id=' + $value.id + '&locationid=' + query.id">Edit</a></td></tr></tbody></table></div></div></div></div>
    <div class="col-12 text-center text-muted py-5" dmx-show="!scLocationDetail.state.executing && scLocationDetail.data.spaces.count() == 0">No spaces have been added to this location.</div>
</div>
<meta name="ac:route" content="/locations/view">

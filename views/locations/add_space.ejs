<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="add_space" appConnect="local" -->
<dmx-serverconnect id="scLocations" url="/api/locations/options" dmx-param:selectedid="query.locationid"></dmx-serverconnect>
<div class="row g-4"><div class="col-12"><div class="d-flex justify-content-between align-items-center"><div><h1 class="mb-1" dmx-text="'Add ' + scTerminology.data.query[0].spaceSingular.lowercase()">Add space</h1><p class="text-muted mb-0">Add a room, auditorium or other space to a location.</p></div><a class="btn btn-outline-secondary" href="/locations">Back</a></div></div><div class="col-12 col-xl-7"><div class="card border-0 shadow-sm"><div class="card-body"><form method="post" action="/api/locations/createSpace"><%- _csrfInput() %><div class="mb-3"><label class="form-label">Location</label><select class="form-select" name="locationId" required dmx-bind:options="scLocations.data.query" optiontext="locationLabel" optionvalue="id" dmx-bind:value="query.locationid"><option value="">Select location</option></select></div><div class="mb-3"><label class="form-label">Space name</label><input class="form-control" name="spaceName" required></div><div class="row g-3"><div class="col-md-6"><label class="form-label">Type</label><input class="form-control" name="spaceType"></div><div class="col-md-6"><label class="form-label">Default capacity</label><input class="form-control" name="defaultCapacity" type="number" min="0"></div></div><div class="mt-4"><button class="btn btn-primary" type="submit">Save space</button> <a class="btn btn-light" href="/locations">Cancel</a></div></form></div></div></div></div>
<meta name="ac:route" content="/locations/add_space">

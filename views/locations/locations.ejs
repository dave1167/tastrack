<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="locations" appConnect="local" components="{dmxStateManagement:{}}" -->
<dmx-serverconnect id="scLocationList" url="/api/locations/list"></dmx-serverconnect>

<div class="row g-4">
    <div class="col-12"><div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3"><div><h1 class="mb-1" dmx-text="scTerminology.data.query[0].locationPlural">Locations</h1><p class="text-muted mb-0">Manage the complete location, space and configuration catalogue.</p></div><div class="d-flex flex-wrap gap-2"><a class="btn btn-primary" href="/locations/create"><i class="fas fa-map-marker-alt me-2"></i><span dmx-text="'Add ' + scTerminology.data.query[0].locationSingular.lowercase()">Add location</span></a><a class="btn btn-outline-primary" href="/locations/add_space"><i class="fas fa-door-open me-2"></i><span dmx-text="'Add ' + scTerminology.data.query[0].spaceSingular.lowercase()">Add space</span></a><a class="btn btn-outline-primary" href="/locations/add_configuration"><i class="fas fa-chair me-2"></i><span dmx-text="'Add ' + scTerminology.data.query[0].configurationSingular.lowercase()">Add configuration</span></a></div></div></div>

    <div class="col-12"><div class="card border-0 shadow-sm"><div class="card-header bg-white d-flex justify-content-between align-items-center"><h2 class="h5 mb-0">All locations</h2><span class="badge rounded-pill bg-primary" dmx-text="scLocationList.data.query.count()"></span></div><div class="card-body p-0"><div class="table-responsive" dmx-show="scLocationList.data.query.count() > 0"><table class="table table-hover align-middle mb-0"><thead class="table-light"><tr><th>Location</th><th>Type</th><th>Address</th><th>Spaces</th><th>Configurations</th><th>Status</th><th class="text-end">Actions</th></tr></thead><tbody is="dmx-repeat" dmx-bind:repeat="scLocationList.data.query"><tr><td class="fw-semibold" dmx-text="locationName"></td><td dmx-text="locationType || '—'"></td><td><span dmx-text="townCity"></span><span dmx-show="townCity && postcode">, </span><span dmx-text="postcode"></span></td><td dmx-text="spaceCount"></td><td dmx-text="configurationCount"></td><td><span class="badge bg-success" dmx-show="isActive == 1">Active</span><span class="badge bg-secondary" dmx-show="isActive != 1">Inactive</span></td><td class="text-end"><div class="d-inline-flex gap-2"><a class="btn btn-sm btn-outline-secondary" dmx-bind:href="'/locations/view?id=' + id"><i class="fas fa-eye me-1"></i>View</a><a class="btn btn-sm btn-outline-primary" dmx-bind:href="'/locations/edit?id=' + id"><i class="fas fa-pen me-1"></i>Edit</a></div></td></tr></tbody></table></div><div class="text-center text-muted py-5" dmx-show="!scLocationList.state.executing && scLocationList.data.query.count() == 0"><i class="fas fa-map-marked-alt fa-2x mb-3"></i><h3 class="h6">No locations yet</h3><p class="small">Use Add location to create the first catalogue record.</p></div></div></div></div>
</div>
<meta name="ac:route" content="/locations">

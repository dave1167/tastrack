<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="edit_location" appConnect="local" -->
<dmx-serverconnect id="scLocation" url="/api/locations/detail" dmx-param:id="query.id"></dmx-serverconnect>
<div class="row g-4"><div class="col-12"><div class="d-flex justify-content-between align-items-center"><div><h1 class="mb-1">Edit location</h1><p class="text-muted mb-0" dmx-text="scLocation.data.location[0].locationName"></p></div><a class="btn btn-outline-secondary" dmx-bind:href="'/locations/view?id=' + query.id">Cancel</a></div></div><div class="col-12 col-xl-9"><div class="card border-0 shadow-sm"><div class="card-body"><form method="post" action="/api/locations/update"><%- _csrfInput() %><input type="hidden" name="id" dmx-bind:value="query.id"><div class="row g-3"><div class="col-md-6"><label class="form-label">Name</label><input class="form-control" name="locationName" required dmx-bind:value="scLocation.data.location[0].locationName"></div><div class="col-md-4"><label class="form-label">Type</label><input class="form-control" name="locationType" dmx-bind:value="scLocation.data.location[0].locationType"></div><div class="col-md-2"><label class="form-label">Status</label><select class="form-select" name="isActive" dmx-bind:value="scLocation.data.location[0].isActive"><option value="1">Active</option><option value="0">Inactive</option></select></div><div class="col-md-6"><label class="form-label">Address line 1</label><input class="form-control" name="addressLine1" dmx-bind:value="scLocation.data.location[0].addressLine1"></div><div class="col-md-6"><label class="form-label">Address line 2</label><input class="form-control" name="addressLine2" dmx-bind:value="scLocation.data.location[0].addressLine2"></div><div class="col-md-3"><label class="form-label">Town or city</label><input class="form-control" name="townCity" dmx-bind:value="scLocation.data.location[0].townCity"></div><div class="col-md-3"><label class="form-label">County or region</label><input class="form-control" name="countyRegion" dmx-bind:value="scLocation.data.location[0].countyRegion"></div><div class="col-md-3"><label class="form-label">Postcode</label><input class="form-control" name="postcode" dmx-bind:value="scLocation.data.location[0].postcode"></div><div class="col-md-3"><label class="form-label">Country</label><input class="form-control" name="country" dmx-bind:value="scLocation.data.location[0].country"></div><div class="col-md-4"><label class="form-label">Telephone</label><input class="form-control" name="telephone" dmx-bind:value="scLocation.data.location[0].telephone"></div><div class="col-md-4"><label class="form-label">Email</label><input class="form-control" name="email" type="email" dmx-bind:value="scLocation.data.location[0].email"></div><div class="col-md-4"><label class="form-label">Website</label><input class="form-control" name="website" dmx-bind:value="scLocation.data.location[0].website"></div></div><div class="mt-4"><button class="btn btn-primary" type="submit">Save changes</button> <a class="btn btn-light" dmx-bind:href="'/locations/view?id=' + query.id">Cancel</a></div></form></div></div></div></div>
<meta name="ac:route" content="/locations/edit">

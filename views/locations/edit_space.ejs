<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="edit_space" appConnect="local" -->
<dmx-serverconnect id="scSpace" url="/api/locations/getSpace" dmx-param:id="query.id"></dmx-serverconnect>
<div class="row g-4"><div class="col-12"><div class="d-flex justify-content-between align-items-center"><div><h1 class="mb-1">Edit space</h1><p class="text-muted mb-0"><span dmx-text="scSpace.data.query[0].locationName"></span> · <span dmx-text="scSpace.data.query[0].spaceName"></span></p></div><a class="btn btn-outline-secondary" dmx-bind:href="'/locations/view?id=' + scSpace.data.query[0].locationId">Cancel</a></div></div><div class="col-12 col-xl-7"><div class="card border-0 shadow-sm"><div class="card-body"><form method="post" action="/api/locations/updateSpace"><%- _csrfInput() %><input type="hidden" name="id" dmx-bind:value="scSpace.data.query[0].id"><input type="hidden" name="locationId" dmx-bind:value="scSpace.data.query[0].locationId"><div class="mb-3"><label class="form-label">Space name</label><input class="form-control" name="spaceName" required dmx-bind:value="scSpace.data.query[0].spaceName"></div><div class="row g-3"><div class="col-md-5"><label class="form-label">Type</label><input class="form-control" name="spaceType" dmx-bind:value="scSpace.data.query[0].spaceType"></div><div class="col-md-4"><label class="form-label">Default capacity</label><input class="form-control" name="defaultCapacity" type="number" min="0" dmx-bind:value="scSpace.data.query[0].defaultCapacity"></div><div class="col-md-3"><label class="form-label">Status</label><select class="form-select" name="isActive" dmx-bind:value="scSpace.data.query[0].isActive"><option value="1">Active</option><option value="0">Inactive</option></select></div><div class="col-12"><label class="form-label">Description</label><textarea class="form-control" name="description" rows="4" dmx-bind:value="scSpace.data.query[0].description"></textarea></div></div><div class="mt-4"><button class="btn btn-primary" type="submit">Save changes</button></div></form></div></div></div></div>
<meta name="ac:route" content="/locations/edit_space">

<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="add_configuration" appConnect="local" -->
<dmx-serverconnect id="scSpaces" url="/api/locations/allSpaces"></dmx-serverconnect>
<div class="row g-4"><div class="col-12"><div class="d-flex justify-content-between align-items-center"><div><h1 class="mb-1" dmx-text="'Add ' + scTerminology.data.query[0].configurationSingular.lowercase()">Add configuration</h1><p class="text-muted mb-0">Add a seating, standing or operational setup to a space.</p></div><a class="btn btn-outline-secondary" href="/locations">Back</a></div></div><div class="col-12 col-xl-7"><div class="card border-0 shadow-sm"><div class="card-body"><form method="post" action="/api/locations/createConfiguration"><%- _csrfInput() %><div class="mb-3"><label class="form-label">Space</label><select class="form-select" name="spaceId" required dmx-bind:options="scSpaces.data.query" optiontext="spaceLabel" optionvalue="id" dmx-bind:value="query.spaceid"><option value="">Select space</option></select></div><div class="mb-3"><label class="form-label">Configuration name</label><input class="form-control" name="configurationName" required></div><div class="row g-3"><div class="col-md-4"><label class="form-label">Seated capacity</label><input class="form-control" name="seatedCapacity" type="number" min="0"></div><div class="col-md-4"><label class="form-label">Standing capacity</label><input class="form-control" name="standingCapacity" type="number" min="0"></div><div class="col-md-4"><label class="form-label">Maximum capacity</label><input class="form-control" name="maximumTotalCapacity" type="number" min="0"></div></div><div class="mt-4"><button class="btn btn-primary" type="submit">Save configuration</button> <a class="btn btn-light" href="/locations">Cancel</a></div></form></div></div></div></div>
<meta name="ac:route" content="/locations/add_configuration">

<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="edit_workflow" appConnect="local" components="{dmxStateManagement:{}}" -->
<dmx-serverconnect id="scWorkflow" url="/api/workflows/get" dmx-param:id="query.id"></dmx-serverconnect><dmx-serverconnect id="scTeams" url="/api/teams/list_teams"></dmx-serverconnect>
<div class="row g-4"><div class="col-12"><div class="d-flex justify-content-between align-items-center"><div><h1 class="mb-1">Edit Workflow</h1><p class="text-muted mb-0" dmx-text="scWorkflow.data.query[0].templateName"></p></div><a class="btn btn-outline-secondary" dmx-bind:href="'/workflows/view?id=' + query.id">Back to workflow</a></div></div><div class="col-12 col-xl-7"><div class="card border-0 shadow-sm"><div class="card-header bg-white"><h2 class="h5 mb-0">Workflow details</h2></div><div class="card-body"><form method="post" action="/api/workflows/update"><%- _csrfInput() %><input type="hidden" name="id" dmx-bind:value="scWorkflow.data.query[0].id"><div class="mb-3"><label class="form-label">Workflow name</label><input class="form-control" name="workflowName" required dmx-bind:value="scWorkflow.data.query[0].workflowName"></div><div class="mb-3"><label class="form-label">Reference code</label><input class="form-control" name="referenceCode" required dmx-bind:value="scWorkflow.data.query[0].referenceCode"></div><div class="row g-3"><div class="col-md-6"><label class="form-label">Owner team</label><select class="form-select" name="ownerTeamId" required dmx-bind:options="scTeams.data.query" optiontext="teamName" optionvalue="id" dmx-bind:value="scWorkflow.data.query[0].ownerTeamId"><option value="">Select team</option></select></div><div class="col-md-6"><label class="form-label">Status</label><select class="form-select" name="status" dmx-bind:value="scWorkflow.data.query[0].status"><option value="draft">Draft</option><option value="not_started">Not started</option><option value="active">Active</option><option value="in_progress">In progress</option><option value="waiting">Waiting</option><option value="complete">Complete</option><option value="cancelled">Cancelled</option><option value="archived">Archived</option></select></div><div class="col-md-6"><label class="form-label">Start date</label><input class="form-control" name="startDate" type="date" required dmx-bind:value="scWorkflow.data.query[0].startDate"></div><div class="col-md-6"><label class="form-label">Target date</label><input class="form-control" name="targetDate" type="date" required dmx-bind:value="scWorkflow.data.query[0].targetDate"></div></div><div class="d-flex gap-2 mt-4"><button class="btn btn-primary" type="submit">Update Workflow</button><a class="btn btn-light" dmx-bind:href="'/workflows/view?id=' + query.id">Cancel</a></div></form></div></div></div></div><meta name="ac:route" content="/workflows/edit">

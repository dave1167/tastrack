<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="workflows" appConnect="local" components="{dmxStateManagement:{}}" -->
<dmx-serverconnect id="scWorkflows" url="/api/workflows/list"></dmx-serverconnect>

<div class="row g-4">
    <div class="col-12">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3">
            <div><h1 class="mb-1" dmx-text="scTerminology.data.query[0].workflowPlural">Workflows</h1><p class="text-muted mb-0">Create and manage live delivery from published templates.</p></div>
            <a class="btn btn-primary" href="/workflows/create"><i class="fas fa-plus me-2"></i><span dmx-text="'New ' + scTerminology.data.query[0].workflowSingular.lowercase()">New workflow</span></a>
        </div>
    </div>
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-3"><h2 class="h5 mb-0" dmx-text="'All ' + scTerminology.data.query[0].workflowPlural.lowercase()">All workflows</h2><span class="badge rounded-pill bg-primary" dmx-text="scWorkflows.data.query.count() + ' ' + (scWorkflows.data.query.count() == 1 ? scTerminology.data.query[0].workflowSingular.lowercase() : scTerminology.data.query[0].workflowPlural.lowercase())"></span></div>
            <div class="card-body">
                <div class="table-responsive"><table class="table table-striped table-hover align-middle mb-0"><thead><tr><th dmx-text="scTerminology.data.query[0].workflowSingular">Workflow</th><th>Template</th><th>Dates</th><th>Progress</th><th>Status</th><th class="text-end">Actions</th></tr></thead><tbody is="dmx-repeat" dmx-bind:repeat="scWorkflows.data.query"><tr><td><div class="fw-semibold" dmx-text="workflowName"></div><div class="text-muted small" dmx-text="referenceCode"></div></td><td dmx-text="templateName"></td><td><div dmx-text="startDate.formatDate('dd MMM yyyy')"></div><div class="small text-muted" dmx-text="'Target: ' + targetDate.formatDate('dd MMM yyyy')"></div></td><td><div class="small" dmx-text="completedStageCount + '/' + stageCount + ' ' + scTerminology.data.query[0].stagePlural.lowercase()"></div><div class="small text-muted" dmx-text="completedTaskCount + '/' + taskCount + ' ' + scTerminology.data.query[0].taskPlural.lowercase()"></div></td><td><span class="badge bg-primary" dmx-text="status.replace('_',' ')"></span></td><td class="text-end"><div class="d-inline-flex gap-2"><a class="btn btn-sm btn-primary" dmx-bind:href="'/workflows/view?id=' + id">Open</a><a class="btn btn-sm btn-outline-primary" dmx-bind:href="'/workflows/edit?id=' + id">Edit</a></div></td></tr></tbody></table></div>
                <div class="text-center py-5" dmx-show="!scWorkflows.state.executing && scWorkflows.data.query.count() == 0"><i class="fas fa-route fa-2x text-muted mb-3"></i><h3 class="h6" dmx-text="'No live ' + scTerminology.data.query[0].workflowPlural.lowercase() + ' yet'">No live workflows yet</h3><p class="text-muted small mb-3">Create one from a published template.</p><a class="btn btn-sm btn-primary" href="/workflows/create" dmx-text="'New ' + scTerminology.data.query[0].workflowSingular.lowercase()">New workflow</a></div>
            </div>
        </div>
    </div>
</div>
<meta name="ac:route" content="/workflows">

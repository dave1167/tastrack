<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="create_workflow" appConnect="local" components="{dmxStateManagement:{}}" -->
<dmx-serverconnect id="scTemplates" url="/api/workflows/template_options"></dmx-serverconnect>
<dmx-serverconnect id="scTeams" url="/api/teams/list_teams"></dmx-serverconnect>
<dmx-serverconnect id="scLocations" url="/api/locations/options"></dmx-serverconnect>
<dmx-serverconnect id="scSpaces" url="/api/locations/spaceOptions" dmx-param:locationid="locationId.value"></dmx-serverconnect>
<dmx-serverconnect id="scConfigurations" url="/api/locations/configurationOptions" dmx-param:spaceid="spaceId.value"></dmx-serverconnect>
<dmx-serverconnect id="scWorkflowTypes" url="/api/workflow_types/options"></dmx-serverconnect>

<div class="row g-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="mb-1" dmx-text="'Create ' + scTerminology.data.query[0].workflowSingular">Create workflow</h1>
                <p class="text-muted mb-0" dmx-text="'Start a live ' + scTerminology.data.query[0].workflowSingular.lowercase() + ' from a published template.'">Start from a published template.</p>
            </div>
            <a class="btn btn-outline-secondary" href="/workflows" dmx-text="'Back to ' + scTerminology.data.query[0].workflowPlural.lowercase()">Back</a>
        </div>
    </div>
    <div class="col-12 col-xl-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white"><h2 class="h5 mb-0" dmx-text="scTerminology.data.query[0].workflowSingular + ' details'">Details</h2></div>
            <div class="card-body">
                <form method="post" action="/api/workflows/create">
                    <%- _csrfInput() %>
                    <div class="mb-3"><label class="form-label">Template</label><select class="form-select" name="templateId" required dmx-bind:options="scTemplates.data.query" optiontext="templateName" optionvalue="id"><option value="">Select published template</option></select></div>
                    <div class="mb-3"><label class="form-label" dmx-text="scTerminology.data.query[0].workflowSingular + ' name'">Name</label><input class="form-control" name="workflowName" required></div>
                    <div class="mb-3"><label class="form-label">Reference code</label><input class="form-control" name="referenceCode" required></div>
                    <div class="mb-3">
                        <label class="form-label" dmx-text="scTerminology.data.query[0].workflowSingular + ' type'">Event type</label>
                        <select class="form-select" name="workflowTypeId" dmx-bind:options="scWorkflowTypes.data.query" optiontext="typeName" optionvalue="id">
                            <option value="">No type selected</option>
                        </select>
                        <div class="form-text">Types can be managed by an owner or administrator under Setup.</div>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6"><label class="form-label">Owner team</label><select class="form-select" name="ownerTeamId" required dmx-bind:options="scTeams.data.query" optiontext="teamName" optionvalue="id"><option value="">Select team</option></select></div>
                        <div class="col-md-6"><label class="form-label">Status</label><div class="form-control bg-light">Not started</div><div class="form-text" dmx-text="'Calculated automatically from ' + scTerminology.data.query[0].taskPlural.lowercase() + '.'">Calculated automatically.</div></div>
                        <div class="col-md-6"><label class="form-label">Start date</label><input class="form-control" name="startDate" type="date" required></div>
                        <div class="col-md-6"><label class="form-label">Target date</label><input class="form-control" name="targetDate" type="date" required></div>
                        <div class="col-12"><hr class="my-1"><h3 class="h6 mb-0">Location</h3></div>
                        <div class="col-md-4"><label class="form-label" for="locationId">Location</label><select class="form-select" id="locationId" name="locationId" dmx-bind:options="scLocations.data.query" optiontext="locationLabel" optionvalue="id" dmx-on:changed="spaceId.setValue(''); configurationId.setValue(''); scSpaces.load(); scConfigurations.load()"><option value="">No location selected</option></select></div>
                        <div class="col-md-4"><label class="form-label" for="spaceId">Space</label><select class="form-select" id="spaceId" name="spaceId" dmx-bind:options="scSpaces.data.query" optiontext="spaceLabel" optionvalue="id" dmx-bind:disabled="!locationId.value" dmx-on:changed="configurationId.setValue(''); scConfigurations.load()"><option value="">No space selected</option></select></div>
                        <div class="col-md-4"><label class="form-label" for="configurationId">Configuration</label><select class="form-select" id="configurationId" name="configurationId" dmx-bind:options="scConfigurations.data.query" optiontext="configurationLabel" optionvalue="id" dmx-bind:disabled="!spaceId.value"><option value="">No configuration selected</option></select></div>
                    </div>
                    <div class="alert alert-info mt-4"><i class="fas fa-info-circle me-2"></i><span dmx-text="scTerminology.data.query[0].stagePlural + ', ' + scTerminology.data.query[0].taskPlural.lowercase() + ' and dependencies will be copied from the selected template.'">Template content will be copied.</span></div>
                    <div class="d-flex gap-2"><button class="btn btn-primary" type="submit" dmx-text="'Create ' + scTerminology.data.query[0].workflowSingular">Create</button><a class="btn btn-light" href="/workflows">Cancel</a></div>
                </form>
            </div>
        </div>
    </div>
</div>
<meta name="ac:route" content="/workflows/create">

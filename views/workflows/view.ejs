<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="view_workflow" appConnect="local" components="{dmxStateManagement:{}}" -->
<dmx-serverconnect id="scWorkflow" url="/api/workflows/get" dmx-param:id="query.id"></dmx-serverconnect>
<dmx-serverconnect id="scStages" url="/api/workflows/stages" dmx-param:workflowid="query.id"></dmx-serverconnect>
<dmx-serverconnect id="scTasks" url="/api/workflows/tasks" dmx-param:workflowid="query.id"></dmx-serverconnect>

<div class="row g-4">
    <div class="col-12"><div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3"><div><h1 class="mb-1" dmx-text="scWorkflow.data.query[0].workflowName"></h1><p class="text-muted mb-0"><span dmx-text="scWorkflow.data.query[0].referenceCode"></span><span> · </span><span dmx-text="scWorkflow.data.query[0].templateName"></span></p></div><div class="d-flex gap-2"><a class="btn btn-outline-secondary" href="/workflows">Workflows</a><a class="btn btn-outline-primary" dmx-bind:href="'/workflows/edit?id=' + query.id">Edit</a></div></div></div>

    <div class="col-12"><div class="row g-3"><div class="col-sm-6 col-xl-3"><div class="p-3 bg-white border rounded shadow-sm"><div class="small text-muted">Status</div><div class="fw-semibold text-capitalize" dmx-text="scWorkflow.data.query[0].status.replace('_',' ')"></div></div></div><div class="col-sm-6 col-xl-3"><div class="p-3 bg-white border rounded shadow-sm"><div class="small text-muted">Owner team</div><div class="fw-semibold" dmx-text="scWorkflow.data.query[0].teamName"></div></div></div><div class="col-sm-6 col-xl-3"><div class="p-3 bg-white border rounded shadow-sm"><div class="small text-muted">Start date</div><div class="fw-semibold" dmx-text="scWorkflow.data.query[0].startDate.formatDate('dd MMM yyyy')"></div></div></div><div class="col-sm-6 col-xl-3"><div class="p-3 bg-white border rounded shadow-sm"><div class="small text-muted">Target date</div><div class="fw-semibold" dmx-text="scWorkflow.data.query[0].targetDate.formatDate('dd MMM yyyy')"></div></div></div></div></div>

    <div class="col-12"><div class="card border-0 shadow-sm"><div class="card-header bg-white d-flex justify-content-between align-items-center py-3"><div><h2 class="h5 mb-0">Stages</h2><div class="small text-muted">Stage status is calculated from its tasks.</div></div><span class="badge rounded-pill bg-primary" dmx-text="scStages.data.query.count()"></span></div><div class="card-body"><div is="dmx-repeat" id="repWorkflowStages" dmx-bind:repeat="scStages.data.query"><div class="border rounded p-3 mb-3"><div class="row g-3 align-items-center"><div class="col-auto"><span class="d-block rounded-circle" dmx-bind:style.background-color="$value.colour" style="width: 16px; height: 16px;"></span></div><div class="col"><div class="fw-semibold" dmx-text="$value.stageName"></div><div class="small text-muted" dmx-text="$value.completedTaskCount + '/' + $value.taskCount + ' tasks complete'"></div></div><div class="col-auto"><span class="badge text-capitalize" dmx-class:bg-secondary="$value.status == 'not_started'" dmx-class:bg-primary="$value.status == 'in_progress'" dmx-class:bg-warning="$value.status == 'waiting'" dmx-class:text-dark="$value.status == 'waiting'" dmx-class:bg-success="$value.status == 'complete'" dmx-class:bg-danger="$value.status == 'overdue'" dmx-text="$value.status.replace('_',' ')"></span></div></div></div></div></div></div></div>

    <div class="col-12"><div class="card border-0 shadow-sm"><div class="card-header bg-white d-flex justify-content-between align-items-center py-3"><h2 class="h5 mb-0">Tasks</h2><span class="badge rounded-pill bg-primary" dmx-text="scTasks.data.query.count()"></span></div><div class="card-body"><div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead><tr><th>Task</th><th>Stage</th><th>Priority</th><th>Due</th><th>Status</th><th></th></tr></thead><tbody is="dmx-repeat" id="repWorkflowTasks" dmx-bind:repeat="scTasks.data.query"><tr><td><div class="fw-semibold" dmx-text="$value.taskName"></div><div class="small text-muted" dmx-text="$value.description"></div></td><td dmx-text="$value.stageName"></td><td><span class="badge bg-light text-dark border text-capitalize" dmx-text="$value.priority"></span></td><td dmx-text="$value.dueDate.formatDate('dd MMM yyyy')"></td><td><form class="d-flex gap-2" method="post" action="/api/workflows/update_task_status"><%- _csrfInput() %><input type="hidden" name="id" dmx-bind:value="$value.id"><input type="hidden" name="workflowId" dmx-bind:value="$value.workflowId"><select class="form-select form-select-sm" name="status" dmx-bind:value="$value.status"><option value="not_started">Not started</option><option value="in_progress">In progress</option><option value="waiting">Waiting</option><option value="complete">Complete</option><option value="skipped">Skipped</option><option value="cancelled">Cancelled</option><option value="overdue">Overdue</option></select><button class="btn btn-sm btn-outline-primary" type="submit">Save</button></form></td><td></td></tr></tbody></table></div></div></div></div>
</div><meta name="ac:route" content="/workflows/view">

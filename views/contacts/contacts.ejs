<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="contacts" appConnect="local" components="{dmxBootstrap5TableGenerator:{},dmxStateManagement:{}}" -->
<dmx-query-manager id="query1"></dmx-query-manager>
<dmx-serverconnect id="scContacts" url="/api/contacts/list"></dmx-serverconnect>

<div class="row g-4">
    <div class="col-12">
        <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3">
            <div><h1 class="mb-1">Contacts</h1><p class="text-muted mb-0">Manage reusable contacts for the current tenant.</p></div>
            <div class="d-flex gap-2">
                <a class="btn btn-outline-secondary" href="/contacts/categories"><i class="fas fa-tags me-2"></i>Categories</a>
                <a class="btn btn-primary" href="/contacts/create"><i class="fas fa-user-plus me-2"></i>Add contact</a>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex align-items-center justify-content-between py-3">
                <h2 class="h5 mb-0">All contacts</h2>
                <span class="badge rounded-pill bg-primary" dmx-text="scContacts.data.query.count() + (scContacts.data.query.count() == 1 ? ' contact' : ' contacts')"></span>
            </div>
            <div class="card-body">
                <div class="text-muted small mb-3" dmx-show="scContacts.state.executing"><i class="fas fa-circle-notch fa-spin me-2"></i>Loading contacts...</div>
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle mb-0">
                        <thead><tr><th class="sorting" dmx-on:click="query1.set('sort','contactName');query1.set('dir',query1.data.dir == 'desc' ? 'asc' : 'desc')">Contact</th><th>Category</th><th>Organisation</th><th>Phone</th><th>Location</th><th>Status</th><th class="text-end">Actions</th></tr></thead>
                        <tbody is="dmx-repeat" dmx-bind:repeat="scContacts.data.query" dmx-state="query1" dmx-sort="sort" dmx-order="dir">
                            <tr>
                                <td><div class="fw-semibold" dmx-text="contactName"></div><div class="text-muted small" dmx-text="email"></div></td>
                                <td><span class="badge bg-light text-dark border" dmx-text="contactType"></span></td>
                                <td dmx-text="organisationName"></td><td dmx-text="phone"></td>
                                <td><span dmx-text="city"></span><span dmx-show="city && country">, </span><span dmx-text="country"></span></td>
                                <td><span class="badge bg-success" dmx-show="isActive == 1">Active</span><span class="badge bg-secondary" dmx-show="isActive != 1">Inactive</span></td>
                                <td class="text-end"><div class="d-inline-flex gap-2"><a class="btn btn-sm btn-outline-primary" dmx-bind:href="'/contacts/edit?id=' + id"><i class="fas fa-pen me-1"></i>Edit</a><a class="btn btn-sm btn-outline-danger" dmx-bind:href="'/contacts/delete?id=' + id"><i class="fas fa-user-slash"></i></a></div></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="text-center py-5" dmx-show="!scContacts.state.executing && scContacts.data.query.count() == 0"><i class="fas fa-address-book fa-2x text-muted mb-3"></i><h3 class="h6">No contacts found</h3><p class="text-muted small">Add your first contact to get started.</p></div>
            </div>
        </div>
    </div>
</div>
<meta name="ac:route" content="/contacts">

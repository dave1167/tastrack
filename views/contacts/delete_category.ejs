<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="delete_contact_category" appConnect="local" -->
<dmx-serverconnect id="scCategory" url="/api/contacts/get_category" dmx-param:id="query.id"></dmx-serverconnect>
<div class="row g-4"><div class="col-12"><h1 class="mb-1">Deactivate Contact Category</h1><p class="text-muted">Review the category before continuing.</p></div><div class="col-12 col-xl-6"><div class="card border-0 shadow-sm"><div class="card-header bg-white"><h2 class="h5 mb-0">Confirm deactivation</h2></div><div class="card-body"><div class="alert alert-warning">The category will no longer appear in new contact forms. Existing contacts keep their current category text.</div><dl class="row"><dt class="col-sm-4">Category</dt><dd class="col-sm-8" dmx-text="scCategory.data.query[0].categoryName"></dd><dt class="col-sm-4">Description</dt><dd class="col-sm-8" dmx-text="scCategory.data.query[0].categoryDesc"></dd></dl><form method="post" dmx-bind:action="'/api/contacts/delete_category?id=' + query.id"><%- _csrfInput() %><div class="d-flex gap-2"><button class="btn btn-danger" type="submit">Deactivate Category</button><a class="btn btn-light" href="/contacts/categories">Cancel</a></div></form></div></div></div></div><meta name="ac:route" content="/contacts/delete_category">

<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="edit_contact" appConnect="local" components="{dmxStateManagement:{}}" -->
<dmx-serverconnect id="scContact" url="/api/contacts/get" dmx-param:id="query.id"></dmx-serverconnect><dmx-serverconnect id="scCategories" url="/api/contacts/category_options"></dmx-serverconnect>
<div class="row g-4"><div class="col-12"><div class="d-flex justify-content-between align-items-center gap-3"><div><h1 class="mb-1">Edit Contact</h1><p class="text-muted mb-0">Update contact details and status.</p></div><a class="btn btn-outline-secondary" href="/contacts">Back to contacts</a></div></div>
<div class="col-12 col-xl-9"><div class="card border-0 shadow-sm"><div class="card-header bg-white"><h2 class="h5 mb-0">Contact details</h2></div><div class="card-body"><form method="post" action="/api/contacts/update"><%- _csrfInput() %><input type="hidden" name="id" dmx-bind:value="scContact.data.query[0].id">
<div class="row g-3"><div class="col-md-6"><label class="form-label">Category</label><select class="form-select" name="contactType" dmx-bind:options="scCategories.data.query" optiontext="categoryName" optionvalue="categoryName" dmx-bind:value="scContact.data.query[0].contactType"><option value="">Select category</option></select></div><div class="col-md-6"><label class="form-label">Organisation</label><input class="form-control" name="organisationName" dmx-bind:value="scContact.data.query[0].organisationName"></div>
<div class="col-md-4"><label class="form-label">First name</label><input class="form-control" name="firstName" dmx-bind:value="scContact.data.query[0].firstName"></div><div class="col-md-4"><label class="form-label">Last name</label><input class="form-control" name="lastName" dmx-bind:value="scContact.data.query[0].lastName"></div><div class="col-md-4"><label class="form-label">Display name</label><input class="form-control" name="displayName" required dmx-bind:value="scContact.data.query[0].displayName"></div><div class="col-md-6"><label class="form-label">Email</label><input class="form-control" name="email" type="email" dmx-bind:value="scContact.data.query[0].email"></div><div class="col-md-6"><label class="form-label">Phone</label><input class="form-control" name="phone" dmx-bind:value="scContact.data.query[0].phone"></div>
<div class="col-12"><hr><h3 class="h6">Address</h3></div><div class="col-md-6"><label class="form-label">Address line 1</label><input class="form-control" name="addressLine1" dmx-bind:value="scContact.data.query[0].addressLine1"></div><div class="col-md-6"><label class="form-label">Address line 2</label><input class="form-control" name="addressLine2" dmx-bind:value="scContact.data.query[0].addressLine2"></div><div class="col-md-4"><label class="form-label">City</label><input class="form-control" name="city" dmx-bind:value="scContact.data.query[0].city"></div><div class="col-md-4"><label class="form-label">Region</label><input class="form-control" name="region" dmx-bind:value="scContact.data.query[0].region"></div><div class="col-md-4"><label class="form-label">Postcode</label><input class="form-control" name="postcode" dmx-bind:value="scContact.data.query[0].postcode"></div><div class="col-md-6"><label class="form-label">Country</label><input class="form-control" name="country" dmx-bind:value="scContact.data.query[0].country"></div><div class="col-md-6"><label class="form-label">Status</label><select class="form-select" name="isActive" dmx-bind:value="scContact.data.query[0].isActive"><option value="1">Active</option><option value="0">Inactive</option></select></div><div class="col-12"><label class="form-label">Notes</label><textarea class="form-control" name="notes" rows="4" dmx-bind:value="scContact.data.query[0].notes"></textarea></div></div>
<div class="d-flex gap-2 mt-4"><button class="btn btn-primary" type="submit">Update Contact</button><a class="btn btn-light" href="/contacts">Cancel</a></div></form></div></div></div></div><meta name="ac:route" content="/contacts/edit">

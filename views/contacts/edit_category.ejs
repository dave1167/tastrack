<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="edit_contact_category" appConnect="local" -->
<dmx-serverconnect id="scCategory" url="/api/contacts/get_category" dmx-param:id="query.id"></dmx-serverconnect>
<div class="row g-4"><div class="col-12"><div class="d-flex justify-content-between align-items-center"><div><h1 class="mb-1">Edit Contact Category</h1><p class="text-muted mb-0">Update the category details and availability.</p></div><a class="btn btn-outline-secondary" href="/contacts/categories">Back to categories</a></div></div><div class="col-12 col-xl-6"><div class="card border-0 shadow-sm"><div class="card-header bg-white"><h2 class="h5 mb-0">Category details</h2></div><div class="card-body"><form method="post" action="/api/contacts/update_category"><%- _csrfInput() %><input type="hidden" name="contactCategoryId" dmx-bind:value="scCategory.data.query[0].contactCategoryId"><div class="mb-3"><label class="form-label">Category name</label><input class="form-control" name="categoryName" required dmx-bind:value="scCategory.data.query[0].categoryName"></div><div class="mb-3"><label class="form-label">Description</label><textarea class="form-control" name="categoryDesc" rows="3" dmx-bind:value="scCategory.data.query[0].categoryDesc"></textarea></div><div class="mb-4"><label class="form-label">Status</label><select class="form-select" name="active" dmx-bind:value="scCategory.data.query[0].active"><option value="1">Active</option><option value="0">Inactive</option></select></div><div class="d-flex gap-2"><button class="btn btn-primary" type="submit">Update Category</button><a class="btn btn-light" href="/contacts/categories">Cancel</a></div></form></div></div></div></div><meta name="ac:route" content="/contacts/edit_category">

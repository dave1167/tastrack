<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="delete_contact" appConnect="local" -->
<dmx-serverconnect id="scContact" url="/api/contacts/get" dmx-param:id="query.id"></dmx-serverconnect>
<div class="row g-4"><div class="col-12"><h1 class="mb-1">Deactivate Contact</h1><p class="text-muted">Review the contact before continuing.</p></div><div class="col-12 col-xl-6"><div class="card border-0 shadow-sm"><div class="card-header bg-white"><h2 class="h5 mb-0">Confirm deactivation</h2></div><div class="card-body"><div class="alert alert-warning">The contact will be hidden from active use. Existing workflow links will remain intact.</div><dl class="row"><dt class="col-sm-4">Contact</dt><dd class="col-sm-8" dmx-text="scContact.data.query[0].contactName"></dd><dt class="col-sm-4">Organisation</dt><dd class="col-sm-8" dmx-text="scContact.data.query[0].organisationName"></dd><dt class="col-sm-4">Email</dt><dd class="col-sm-8" dmx-text="scContact.data.query[0].email"></dd></dl><form method="post" dmx-bind:action="'/api/contacts/delete?id=' + query.id"><%- _csrfInput() %><div class="d-flex gap-2"><button class="btn btn-danger" type="submit">Deactivate Contact</button><a class="btn btn-light" href="/contacts">Cancel</a></div></form></div></div></div></div><meta name="ac:route" content="/contacts/delete">

wel<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="dashboard" appConnect="local" -->
<dmx-serverconnect id="scSessionContext" url="/api/security/sessionContext"></dmx-serverconnect>
<dmx-serverconnect id="serverconnect1"></dmx-serverconnect>

<div class="row g-4">
    <div class="col-12">
        <h1 class="mb-1">Dashboard</h1>
        <p class="text-muted mb-0">Session values set during login.</p>
    </div>

    <div class="col-12 col-xl-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h2 class="h5 mb-0">Session check</h2>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-12 col-md-4">
                        <div class="p-3 rounded border bg-light">
                            <div class="small text-muted">User ID</div>
                            <div class="fs-5 fw-semibold">{{scSessionContext.data.USER_ID}}</div>
                            <input id="text1" name="text1" type="text" class="form-control">
                        </div>
                    </div>

                    <div class="col-12 col-md-4">
                        <div class="p-3 rounded border bg-light">
                            <div class="small text-muted">Tenant ID</div>
                            <div class="fs-5 fw-semibold">{{scSessionContext.data.TENANT_ID}}</div>
                        </div>
                    </div>

                    <div class="col-12 col-md-4">
                        <div class="p-3 rounded border bg-light">
                            <div class="small text-muted">Role ID</div>
                            <div class="fs-5 fw-semibold">{{scSessionContext.data.ROLE_ID}}</div>
                        </div>
                    </div>

                    <div class="col-12 col-md-4">
                        <div class="p-3 rounded border bg-light">
                            <div class="small text-muted">Tenant Name</div>
                            <div class="fs-6 fw-semibold">{{scSessionContext.data.TENANT_NAME}}</div>
                        </div>
                    </div>

                    <div class="col-12 col-md-4">
                        <div class="p-3 rounded border bg-light">
                            <div class="small text-muted">First Name</div>
                            <div class="fs-6 fw-semibold">{{scSessionContext.data.FNAME}}</div>
                        </div>
                    </div>

                    <div class="col-12 col-md-4">
                        <div class="p-3 rounded border bg-light">
                            <div class="small text-muted">Last Name</div>
                            <div class="fs-6 fw-semibold">{{scSessionContext.data.LNAME}}</div>
                        </div>
                    </div>

                    <div class="col-12 col-md-4">
                        <div class="p-3 rounded border bg-light">
                            <div class="small text-muted">Display Name</div>
                            <div class="fs-6 fw-semibold">{{scSessionContext.data.DISPLAY_NAME}}</div>
                        </div>
                    </div>

                    <div class="col-12 col-md-4">
                        <div class="p-3 rounded border bg-light">
                            <div class="small text-muted">Role Name</div>
                            <div class="fs-6 fw-semibold">{{scSessionContext.data.ROLE_NAME}}</div>
                        </div>
                    </div>

                    <div class="col-12 col-md-4">
                        <div class="p-3 rounded border bg-light">
                            <div class="small text-muted">Role Key</div>
                            <div class="fs-6 fw-semibold">{{scSessionContext.data.ROLE_KEY}}</div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>
<meta name="ac:route" content="/">
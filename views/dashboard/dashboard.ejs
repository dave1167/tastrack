<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="dashboard" appConnect="local" components="{dmxStateManagement:{}}" -->
<dmx-serverconnect id="scSessionContext" url="/api/security/sessionContext"></dmx-serverconnect>
<dmx-serverconnect id="scDashboard" dmx-bind:url="query.scope == 'all' ? '/api/dashboard/overview' : '/api/dashboard/overview_user'"></dmx-serverconnect>

<div class="row g-4">
    <div class="col-12">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3">
            <div><h1 class="mb-1">Dashboard</h1><p class="text-muted mb-0">Welcome back, <span dmx-text="scSessionContext.data.DISPLAY_NAME"></span>. Here is what needs attention across <span dmx-text="scSessionContext.data.TENANT_NAME"></span>.</p></div>
            <div class="d-flex gap-2 align-items-center"><div class="btn-group" role="group" aria-label="Dashboard scope"><a class="btn btn-outline-primary" dmx-class:active="query.scope != 'all'" href="/">My work</a><a class="btn btn-outline-primary" dmx-class:active="query.scope == 'all'" href="/?scope=all">All work</a></div><a class="btn btn-primary" href="/workflows/create"><i class="fas fa-plus me-2"></i><span dmx-text="'New ' + scTerminology.data.query[0].workflowSingular.lowercase()">New workflow</span></a></div>
        </div>
    </div>

    <div class="col-6 col-lg-4 col-xxl-2"><a class="card border-0 shadow-sm h-100 text-decoration-none text-reset" href="/workflows"><div class="card-body"><div class="d-flex justify-content-between"><div><div class="small text-muted" dmx-text="'Active ' + scTerminology.data.query[0].workflowPlural.lowercase()">Active workflows</div><div class="fs-2 fw-semibold" dmx-text="scDashboard.data.summary[0].activeWorkflows"></div></div><div class="text-primary"><i class="fas fa-route fa-lg"></i></div></div></div></a></div>
    <div class="col-6 col-lg-4 col-xxl-2"><a class="card border-0 shadow-sm h-100 text-decoration-none text-reset" href="/tasks"><div class="card-body"><div class="d-flex justify-content-between"><div><div class="small text-muted" dmx-text="'Open ' + scTerminology.data.query[0].taskPlural.lowercase()">Open tasks</div><div class="fs-2 fw-semibold" dmx-text="scDashboard.data.summary[0].openTasks"></div></div><div class="text-primary"><i class="fas fa-tasks fa-lg"></i></div></div></div></a></div>
    <div class="col-6 col-lg-4 col-xxl-2"><div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="d-flex justify-content-between"><div><div class="small text-muted">Overdue</div><div class="fs-2 fw-semibold text-danger" dmx-text="scDashboard.data.summary[0].overdueTasks"></div></div><div class="text-danger"><i class="fas fa-exclamation-circle fa-lg"></i></div></div></div></div></div>
    <div class="col-6 col-lg-4 col-xxl-2"><div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="d-flex justify-content-between"><div><div class="small text-muted">Due in 7 days</div><div class="fs-2 fw-semibold text-warning" dmx-text="scDashboard.data.summary[0].dueSoonTasks"></div></div><div class="text-warning"><i class="fas fa-calendar-alt fa-lg"></i></div></div></div></div></div>
    <div class="col-6 col-lg-4 col-xxl-2"><div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="d-flex justify-content-between"><div><div class="small text-muted" dmx-text="'My open ' + scTerminology.data.query[0].taskPlural.lowercase()">My open tasks</div><div class="fs-2 fw-semibold" dmx-text="scDashboard.data.summary[0].myOpenTasks"></div></div><div class="text-info"><i class="fas fa-user-check fa-lg"></i></div></div></div></div></div>
    <div class="col-6 col-lg-4 col-xxl-2"><div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="d-flex justify-content-between"><div><div class="small text-muted">Unassigned</div><div class="fs-2 fw-semibold" dmx-text="scDashboard.data.summary[0].unassignedTasks"></div></div><div class="text-secondary"><i class="fas fa-user-slash fa-lg"></i></div></div></div></div></div>

    <div class="col-12"><div class="card border-0 shadow-sm"><div class="card-header bg-white d-flex justify-content-between align-items-center py-3"><h2 class="h5 mb-0" dmx-text="(query.scope == 'all' ? 'All ' : 'My ') + scTerminology.data.query[0].taskSingular.lowercase() + ' statuses'">My task statuses</h2><span class="text-muted small" dmx-text="query.scope == 'all' ? 'All allocated ' + scTerminology.data.query[0].taskPlural.lowercase() : scTerminology.data.query[0].taskPlural + ' allocated to me'">Tasks allocated to me</span></div><div class="card-body"><div class="row g-2" is="dmx-repeat" dmx-bind:repeat="scDashboard.data.taskStatus"><div class="col-6 col-md-4 col-xl"><div class="border rounded p-3 h-100"><div class="small text-muted text-capitalize" dmx-text="status.replace('_',' ')"></div><div class="fs-3 fw-semibold" dmx-text="taskCount"></div></div></div></div><div class="text-muted small" dmx-show="scDashboard.data.taskStatus.count() == 0" dmx-text="'No allocated ' + scTerminology.data.query[0].taskPlural.lowercase() + ' in this view.'">No allocated tasks in this view.</div></div></div></div>

    <div class="col-12 col-xl-7">
        <div class="card border-0 shadow-sm h-100"><div class="card-header bg-white d-flex justify-content-between align-items-center py-3"><h2 class="h5 mb-0" dmx-text="'Upcoming ' + scTerminology.data.query[0].taskSingular.lowercase() + ' deadlines'">Upcoming task deadlines</h2><span class="text-muted small">Next 12 by due date</span></div><div class="card-body"><div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead><tr><th dmx-text="scTerminology.data.query[0].taskSingular">Task</th><th>Owner</th><th>Due</th><th>Priority</th></tr></thead><tbody is="dmx-repeat" dmx-bind:repeat="scDashboard.data.upcomingTasks"><tr><td><a class="fw-semibold text-decoration-none" dmx-bind:href="'/workflows/view?id=' + workflowId" dmx-text="taskName"></a><div class="small text-muted"><span dmx-text="workflowName"></span><span> · </span><span dmx-text="stageName"></span></div></td><td dmx-text="assigneeName"></td><td><span dmx-class:text-danger="isOverdue == 1" dmx-class:fw-semibold="isOverdue == 1" dmx-text="dueDate.formatDate('dd MMM yyyy')"></span><div class="small text-danger" dmx-show="isOverdue == 1">Overdue</div></td><td><span class="badge text-capitalize" dmx-class:bg-danger="priority == 'urgent'" dmx-class:bg-warning="priority == 'high'" dmx-class:text-dark="priority == 'high'" dmx-class:bg-primary="priority == 'normal'" dmx-class:bg-secondary="priority == 'low'" dmx-text="priority"></span></td></tr></tbody></table></div><div class="text-muted small py-4 text-center" dmx-show="!scDashboard.state.executing && scDashboard.data.upcomingTasks.count() == 0" dmx-text="'No open ' + scTerminology.data.query[0].taskPlural.lowercase() + ' currently have a due date.'">No open tasks currently have a due date.</div></div></div>
    </div>

    <div class="col-12 col-xl-5">
        <div class="card border-0 shadow-sm mb-4"><div class="card-header bg-white py-3"><h2 class="h5 mb-0" dmx-text="scTerminology.data.query[0].workflowSingular + ' health'">Workflow health</h2></div><div class="card-body"><div class="d-flex flex-wrap gap-2" is="dmx-repeat" dmx-bind:repeat="scDashboard.data.workflowHealth"><span class="badge bg-light text-dark border fs-6 fw-normal"><span class="text-capitalize" dmx-text="status.replace('_',' ')"></span><span class="badge bg-primary ms-2" dmx-text="workflowCount"></span></span></div><div class="text-muted small" dmx-show="scDashboard.data.workflowHealth.count() == 0" dmx-text="'No ' + scTerminology.data.query[0].workflowPlural.lowercase() + ' have been created yet.'">No workflows have been created yet.</div></div></div>
        <div class="card border-0 shadow-sm"><div class="card-header bg-white d-flex justify-content-between py-3"><h2 class="h5 mb-0" dmx-text="'Open ' + scTerminology.data.query[0].taskPlural.lowercase() + ' by priority'">Open tasks by priority</h2><span class="text-muted small"><span dmx-text="scDashboard.data.summary[0].completedLast30Days"></span> completed in 30 days</span></div><div class="card-body"><div class="row g-2" is="dmx-repeat" dmx-bind:repeat="scDashboard.data.priorityBreakdown"><div class="col-6"><div class="border rounded p-3"><div class="small text-muted text-capitalize" dmx-text="priority"></div><div class="fs-4 fw-semibold" dmx-text="taskCount"></div></div></div></div><div class="text-muted small" dmx-show="scDashboard.data.priorityBreakdown.count() == 0" dmx-text="'No open ' + scTerminology.data.query[0].taskPlural.lowercase() + '.'">No open tasks.</div></div></div>
    </div>

    <div class="col-12 col-xl-6"><div class="card border-0 shadow-sm h-100"><div class="card-header bg-white py-3"><h2 class="h5 mb-0" dmx-text="scTerminology.data.query[0].taskPlural + ' by user'">Tasks by user</h2></div><div class="card-body"><div class="table-responsive"><table class="table table-sm align-middle mb-0"><thead><tr><th>User</th><th class="text-end">In progress</th><th class="text-end">Overdue</th><th class="text-end">Open</th></tr></thead><tbody is="dmx-repeat" dmx-bind:repeat="scDashboard.data.tasksByUser"><tr><td class="fw-semibold" dmx-text="displayName"></td><td class="text-end" dmx-text="inProgressCount"></td><td class="text-end text-danger" dmx-text="overdueCount"></td><td class="text-end"><span class="badge bg-primary" dmx-text="openTaskCount"></span></td></tr></tbody></table></div><div class="text-muted small py-3" dmx-show="scDashboard.data.tasksByUser.count() == 0" dmx-text="'No ' + scTerminology.data.query[0].taskPlural.lowercase() + ' are assigned directly to users.'">No tasks are assigned directly to users.</div></div></div></div>

    <div class="col-12 col-xl-6"><div class="card border-0 shadow-sm h-100"><div class="card-header bg-white py-3"><h2 class="h5 mb-0" dmx-text="scTerminology.data.query[0].taskPlural + ' by team'">Tasks by team</h2></div><div class="card-body"><div class="table-responsive"><table class="table table-sm align-middle mb-0"><thead><tr><th>Team</th><th class="text-end">Overdue</th><th class="text-end">Open</th></tr></thead><tbody is="dmx-repeat" dmx-bind:repeat="scDashboard.data.tasksByTeam"><tr><td class="fw-semibold" dmx-text="teamName"></td><td class="text-end text-danger" dmx-text="overdueCount"></td><td class="text-end"><span class="badge bg-primary" dmx-text="openTaskCount"></span></td></tr></tbody></table></div><div class="text-muted small py-3" dmx-show="scDashboard.data.tasksByTeam.count() == 0" dmx-text="'No ' + scTerminology.data.query[0].taskPlural.lowercase() + ' are assigned directly to teams.'">No tasks are assigned directly to teams.</div></div></div></div>

    <div class="col-12"><div class="card border-0 shadow-sm"><div class="card-header bg-white d-flex justify-content-between align-items-center py-3"><h2 class="h5 mb-0" dmx-text="'Recently updated ' + scTerminology.data.query[0].workflowPlural.lowercase()">Recently updated workflows</h2><a class="btn btn-sm btn-outline-primary" href="/workflows" dmx-text="'View all ' + scTerminology.data.query[0].workflowPlural.lowercase()">View all</a></div><div class="card-body"><div class="row g-3" is="dmx-repeat" dmx-bind:repeat="scDashboard.data.recentWorkflows"><div class="col-12 col-md-6 col-xl-4"><a class="d-block border rounded p-3 text-decoration-none text-reset h-100" dmx-bind:href="'/workflows/view?id=' + id"><div class="d-flex justify-content-between gap-2"><div class="fw-semibold" dmx-text="workflowName"></div><span class="badge bg-light text-dark border text-capitalize" dmx-text="status.replace('_',' ')"></span></div><div class="small text-muted mt-1" dmx-text="templateName"></div><div class="small mt-3"><span dmx-text="completedTaskCount + '/' + taskCount + ' ' + scTerminology.data.query[0].taskPlural.lowercase() + ' complete'"></span><span class="float-end text-muted" dmx-text="targetDate.formatDate('dd MMM')"></span></div></a></div></div><div class="text-muted small" dmx-show="scDashboard.data.recentWorkflows.count() == 0" dmx-text="'No ' + scTerminology.data.query[0].workflowPlural.lowercase() + ' have been created yet.'">No workflows have been created yet.</div></div></div></div>
</div>
<meta name="ac:route" content="/">

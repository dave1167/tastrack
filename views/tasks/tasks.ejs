<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="tasks" appConnect="local" components="{dmxStateManagement:{}}" -->
<dmx-query-manager id="queryView"></dmx-query-manager>
<dmx-serverconnect id="scTasks" url="/api/tasks/overview"></dmx-serverconnect>
<dmx-serverconnect id="scStageOverview" url="/api/tasks/stage_overview"></dmx-serverconnect>
<dmx-serverconnect id="scPerspectives" url="/api/tasks/perspectives"></dmx-serverconnect>

<div class="row g-4">
    <div class="col-12">
        <div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-3">
            <div><h1 class="mb-1" dmx-text="scTerminology.data.query[0].taskPlural">Tasks</h1><p class="text-muted mb-0">See what is next, where work is blocked, and how workload is distributed.</p></div>
            <div class="btn-group" role="group" aria-label="Task perspective">
                <button class="btn btn-outline-primary" dmx-class:active="!queryView.data.view || queryView.data.view == 'overview'" dmx-on:click="queryView.set('view','overview')"><i class="fas fa-binoculars me-2"></i>Overview</button>
                <button class="btn btn-outline-primary" dmx-class:active="queryView.data.view == 'user'" dmx-on:click="queryView.set('view','user')"><i class="fas fa-user me-2"></i>By user</button>
                <button class="btn btn-outline-primary" dmx-class:active="queryView.data.view == 'team'" dmx-on:click="queryView.set('view','team')"><i class="fas fa-users me-2"></i>By team</button>
            </div>
        </div>
    </div>

    <div class="col-6 col-lg-4 col-xl"><div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="small text-muted">Open</div><div class="fs-2 fw-semibold" dmx-text="scTasks.data.summary[0].openTasks"></div></div></div></div>
    <div class="col-6 col-lg-4 col-xl"><div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="small text-muted">Overdue</div><div class="fs-2 fw-semibold text-danger" dmx-text="scTasks.data.summary[0].overdueTasks"></div></div></div></div>
    <div class="col-6 col-lg-4 col-xl"><div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="small text-muted">Due in 7 days</div><div class="fs-2 fw-semibold text-warning" dmx-text="scTasks.data.summary[0].dueSoonTasks"></div></div></div></div>
    <div class="col-6 col-lg-4 col-xl"><div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="small text-muted">My tasks</div><div class="fs-2 fw-semibold text-primary" dmx-text="scTasks.data.summary[0].myTasks"></div></div></div></div>
    <div class="col-6 col-lg-4 col-xl"><div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="small text-muted">Unassigned</div><div class="fs-2 fw-semibold" dmx-text="scTasks.data.summary[0].unassignedTasks"></div></div></div></div>
    <div class="col-6 col-lg-4 col-xl"><div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="small text-muted">Done in 30 days</div><div class="fs-2 fw-semibold text-success" dmx-text="scTasks.data.summary[0].completedLast30Days"></div></div></div></div>

    <div class="col-12" dmx-show="!queryView.data.view || queryView.data.view == 'overview'">
        <div class="d-flex justify-content-between align-items-center mb-3"><div><h2 class="h4 mb-1" dmx-text="scTerminology.data.query[0].workflowSingular + ' ' + scTerminology.data.query[0].stagePlural.lowercase()">Workflow stages</h2><p class="text-muted small mb-0">The next due item is shown for each section. Expand one to see everything beneath it.</p></div><span class="badge rounded-pill bg-primary" dmx-text="scStageOverview.data.query.count() + ' ' + scTerminology.data.query[0].stagePlural.lowercase()"></span></div>

        <div is="dmx-repeat" id="repStageOverview" dmx-bind:repeat="scStageOverview.data.query">
            <div class="card border-0 shadow-sm mb-3" dmx-class:border-danger="$value.overdueTaskCount > 0">
                <div class="card-body">
                    <div class="row g-3 align-items-center">
                        <div class="col-auto"><span class="d-block rounded-circle" dmx-bind:style.background-color="$value.colour" style="width: 18px; height: 18px;"></span></div>
                        <div class="col-12 col-md-3"><a class="fw-semibold text-decoration-none" dmx-bind:href="'/workflows/view?id=' + $value.workflowId" dmx-text="$value.workflowName"></a><div class="small text-muted"><span dmx-text="$value.stageName"></span><span> · </span><span dmx-text="$value.completedTaskCount + '/' + $value.taskCount + ' complete'"></span></div></div>
                        <div class="col"><div class="small text-muted text-uppercase">Next task</div><div class="fw-semibold" dmx-show="$value.nextTaskId" dmx-text="$value.nextTaskName"></div><div class="text-muted" dmx-show="!$value.nextTaskId">No open task</div><div class="small text-muted" dmx-show="$value.nextTaskId"><span dmx-text="$value.nextAssignee"></span><span dmx-show="$value.nextDueDate"> · Due </span><span dmx-text="$value.nextDueDate.formatDate('dd MMM yyyy')"></span></div></div>
                        <div class="col-auto"><span class="badge text-capitalize" dmx-class:bg-danger="$value.stageStatus == 'overdue'" dmx-class:bg-primary="$value.stageStatus == 'in_progress'" dmx-class:bg-warning="$value.stageStatus == 'waiting'" dmx-class:text-dark="$value.stageStatus == 'waiting'" dmx-class:bg-success="$value.stageStatus == 'complete'" dmx-class:bg-secondary="$value.stageStatus == 'not_started'" dmx-text="$value.stageStatus.replace('_',' ')"></span></div>
                        <div class="col-auto"><button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" dmx-bind:data-bs-target="'#stageTasks' + $value.stageId" dmx-bind:aria-controls="'stageTasks' + $value.stageId" aria-expanded="false" aria-label="Show all tasks"><i class="fas fa-chevron-down"></i></button></div>
                    </div>
                </div>

                <div class="collapse" dmx-bind:id="'stageTasks' + $value.stageId">
                    <div class="border-top">
                        <div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead class="table-light"><tr><th>Task</th><th>Assigned to</th><th>Due</th><th>Priority</th><th>Blockers</th><th>Status</th><th></th></tr></thead>
                            <tbody is="dmx-repeat" dmx-bind:repeat="scTasks.data.query.where('workflowStageId',$value.stageId)"><tr><td><div class="fw-semibold" dmx-text="$value.taskName"></div><div class="small text-muted" dmx-text="$value.description"></div></td><td dmx-text="$value.assigneeName"></td><td><span dmx-class:text-danger="$value.isOverdue == 1" dmx-text="$value.dueDate.formatDate('dd MMM yyyy')"></span></td><td><span class="badge bg-light text-dark border text-capitalize" dmx-text="$value.priority"></span></td><td><span class="badge bg-danger" dmx-show="$value.incompleteBlockerCount > 0" dmx-text="$value.incompleteBlockerCount"></span><span dmx-show="$value.incompleteBlockerCount == 0">—</span></td><td><form class="d-flex gap-2" method="post" action="/api/tasks/update_status"><%- _csrfInput() %><input type="hidden" name="id" dmx-bind:value="$value.id"><select class="form-select form-select-sm" name="status" dmx-bind:value="$value.status"><option value="not_started">Not started</option><option value="in_progress">In progress</option><option value="waiting">Waiting</option><option value="complete">Complete</option><option value="skipped">Skipped</option><option value="cancelled">Cancelled</option></select><button class="btn btn-sm btn-outline-primary" type="submit">Save</button></form></td><td><a class="btn btn-sm btn-outline-secondary" dmx-bind:href="'/tasks/edit?id=' + $value.id"><i class="fas fa-pen"></i></a></td></tr></tbody>
                        </table></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="text-center text-muted py-5" dmx-show="!scStageOverview.state.executing && scStageOverview.data.query.count() == 0">No active workflow stages to show.</div>
    </div>

    <div class="col-12" dmx-show="queryView.data.view == 'user'">
        <div class="mb-3"><h2 class="h4 mb-1">Workload by user</h2><p class="text-muted small mb-0">A people-focused view of open work, risk and recent throughput.</p></div>
        <div class="row g-3" is="dmx-repeat" dmx-bind:repeat="scPerspectives.data.byUser"><div class="col-12 col-md-6 col-xl-4"><div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="d-flex justify-content-between"><h3 class="h6 mb-3" dmx-text="displayName"></h3><span class="badge bg-primary" dmx-text="openTaskCount + ' open'"></span></div><div class="row g-2 text-center"><div class="col-4"><div class="border rounded p-2"><div class="small text-muted">Working</div><strong dmx-text="inProgressCount"></strong></div></div><div class="col-4"><div class="border rounded p-2"><div class="small text-muted">Overdue</div><strong class="text-danger" dmx-text="overdueCount"></strong></div></div><div class="col-4"><div class="border rounded p-2"><div class="small text-muted">Due soon</div><strong class="text-warning" dmx-text="dueSoonCount"></strong></div></div></div><div class="small text-muted mt-3"><span dmx-text="completedLast30"></span> completed in the last 30 days</div></div></div></div></div>
    </div>

    <div class="col-12" dmx-show="queryView.data.view == 'team'">
        <div class="mb-3"><h2 class="h4 mb-1">Workload by team</h2><p class="text-muted small mb-0">Department-level capacity, deadlines and delivery risk.</p></div>
        <div class="row g-3" is="dmx-repeat" dmx-bind:repeat="scPerspectives.data.byTeam"><div class="col-12 col-md-6 col-xl-4"><div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="d-flex justify-content-between"><h3 class="h6 mb-3" dmx-text="teamName"></h3><span class="badge bg-primary" dmx-text="openTaskCount + ' open'"></span></div><div class="row g-2 text-center"><div class="col-4"><div class="border rounded p-2"><div class="small text-muted">Working</div><strong dmx-text="inProgressCount"></strong></div></div><div class="col-4"><div class="border rounded p-2"><div class="small text-muted">Overdue</div><strong class="text-danger" dmx-text="overdueCount"></strong></div></div><div class="col-4"><div class="border rounded p-2"><div class="small text-muted">Due soon</div><strong class="text-warning" dmx-text="dueSoonCount"></strong></div></div></div><div class="small text-muted mt-3"><span dmx-text="completedLast30"></span> completed in the last 30 days</div></div></div></div></div>
    </div>
</div>
<meta name="ac:route" content="/tasks">

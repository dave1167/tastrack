<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="tasks" appConnect="local" components="{dmxStateManagement:{}}" -->
<dmx-serverconnect id="scTasks" url="/api/tasks/overview"></dmx-serverconnect>

<div class="row g-4">
    <div class="col-12"><div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3"><div><h1 class="mb-1">Tasks</h1><p class="text-muted mb-0">Triage and manage tasks across all live workflows.</p></div><a class="btn btn-outline-primary" href="/workflows"><i class="fas fa-route me-2"></i>View workflows</a></div></div>

    <div class="col-6 col-lg-4 col-xl"><div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="small text-muted">Open</div><div class="fs-2 fw-semibold" dmx-text="scTasks.data.summary[0].openTasks"></div></div></div></div>
    <div class="col-6 col-lg-4 col-xl"><div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="small text-muted">Overdue</div><div class="fs-2 fw-semibold text-danger" dmx-text="scTasks.data.summary[0].overdueTasks"></div></div></div></div>
    <div class="col-6 col-lg-4 col-xl"><div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="small text-muted">Due in 7 days</div><div class="fs-2 fw-semibold text-warning" dmx-text="scTasks.data.summary[0].dueSoonTasks"></div></div></div></div>
    <div class="col-6 col-lg-4 col-xl"><div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="small text-muted">My tasks</div><div class="fs-2 fw-semibold text-primary" dmx-text="scTasks.data.summary[0].myTasks"></div></div></div></div>
    <div class="col-6 col-lg-4 col-xl"><div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="small text-muted">Unassigned</div><div class="fs-2 fw-semibold" dmx-text="scTasks.data.summary[0].unassignedTasks"></div></div></div></div>
    <div class="col-6 col-lg-4 col-xl"><div class="card border-0 shadow-sm h-100"><div class="card-body"><div class="small text-muted">Done in 30 days</div><div class="fs-2 fw-semibold text-success" dmx-text="scTasks.data.summary[0].completedLast30Days"></div></div></div></div>

    <div class="col-12"><div class="card border-0 shadow-sm"><div class="card-header bg-white d-flex justify-content-between align-items-center py-3"><h2 class="h5 mb-0">Current tasks</h2><span class="text-muted small">Open tasks plus completions from the last 30 days</span></div><div class="card-body"><div class="table-responsive"><table class="table table-striped table-hover align-middle mb-0"><thead><tr><th>Task</th><th>Workflow / stage</th><th>Assigned to</th><th>Due</th><th>Priority</th><th>Blockers</th><th>Status</th><th></th></tr></thead>
        <tbody is="dmx-repeat" id="repAllTasks" dmx-bind:repeat="scTasks.data.query"><tr dmx-class:table-danger="$value.isOverdue == 1"><td><div class="fw-semibold" dmx-text="$value.taskName"></div><div class="small text-muted" dmx-text="$value.description"></div></td><td><a class="text-decoration-none fw-semibold" dmx-bind:href="'/workflows/view?id=' + $value.workflowId" dmx-text="$value.workflowName"></a><div class="small text-muted" dmx-text="$value.stageName"></div></td><td><span dmx-text="$value.assigneeName"></span><div class="small text-muted text-capitalize" dmx-text="$value.assigneeType"></div></td><td><span dmx-class:text-danger="$value.isOverdue == 1" dmx-class:fw-semibold="$value.isOverdue == 1" dmx-text="$value.dueDate.formatDate('dd MMM yyyy')"></span><div class="small text-danger" dmx-show="$value.isOverdue == 1">Overdue</div></td><td><span class="badge text-capitalize" dmx-class:bg-danger="$value.priority == 'urgent'" dmx-class:bg-warning="$value.priority == 'high'" dmx-class:text-dark="$value.priority == 'high'" dmx-class:bg-primary="$value.priority == 'normal'" dmx-class:bg-secondary="$value.priority == 'low'" dmx-text="$value.priority"></span></td><td><span class="badge bg-danger" dmx-show="$value.incompleteBlockerCount > 0" dmx-text="$value.incompleteBlockerCount + ' blocking'"></span><span class="text-muted" dmx-show="$value.incompleteBlockerCount == 0">—</span></td><td><form class="d-flex gap-2" method="post" action="/api/tasks/update_status"><%- _csrfInput() %><input type="hidden" name="id" dmx-bind:value="$value.id"><select class="form-select form-select-sm" name="status" dmx-bind:value="$value.status"><option value="not_started">Not started</option><option value="in_progress">In progress</option><option value="waiting">Waiting</option><option value="complete">Complete</option><option value="skipped">Skipped</option><option value="cancelled">Cancelled</option><option value="overdue">Overdue</option></select><button class="btn btn-sm btn-outline-primary" type="submit">Save</button></form></td><td class="text-end"><a class="btn btn-sm btn-outline-secondary" dmx-bind:href="'/tasks/edit?id=' + $value.id"><i class="fas fa-pen"></i></a></td></tr></tbody>
    </table></div><div class="text-center text-muted py-5" dmx-show="!scTasks.state.executing && scTasks.data.query.count() == 0">No tasks to show.</div></div></div></div>
</div><meta name="ac:route" content="/tasks">

<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="tasks" appConnect="local" components="{dmxStateManagement:{}}" -->
<dmx-serverconnect id="scTasks" url="/api/tasks/inbox" dmx-param:view="query.view.default('my')" dmx-param:search="query.search" dmx-param:workflowid="query.workflowid" dmx-param:status="query.status.default('open')" dmx-param:priority="query.priority" dmx-param:due="query.due" dmx-param:blocked="query.blocked"></dmx-serverconnect>
<dmx-serverconnect id="scWorkflows" url="/api/workflows/list"></dmx-serverconnect>
<dmx-serverconnect id="scNextTasks" url="/api/tasks/next_by_workflow"></dmx-serverconnect>

<div id="taskCsrfSource" class="d-none"><%- _csrfInput() %></div>

<div class="row g-4">
    <div class="col-12">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
            <div>
                <h1 class="mb-1" dmx-text="scTerminology.data.query[0].taskSingular + ' inbox'">Task inbox</h1>
                <p class="text-muted mb-0" dmx-text="'Find and act on ' + scTerminology.data.query[0].taskPlural.lowercase() + ' across all ' + scTerminology.data.query[0].workflowPlural.lowercase() + '.'">Find and act on tasks across all workflows.</p>
            </div>
            <span class="badge rounded-pill bg-primary fs-6 fw-normal" dmx-text="scTasks.data.query.count() + (scTasks.data.query.count() == 1 ? ' ' + scTerminology.data.query[0].taskSingular.lowercase() : ' ' + scTerminology.data.query[0].taskPlural.lowercase())"></span>
        </div>
    </div>

    <div class="col-12">
        <div class="nav nav-pills gap-2" role="navigation" aria-label="Task inbox view">
            <a class="nav-link" dmx-class:active="!query.view || query.view == 'my'" href="/tasks?view=my"><i class="fas fa-user me-2"></i>My tasks</a>
            <a class="nav-link" dmx-class:active="query.view == 'team'" href="/tasks?view=team"><i class="fas fa-users me-2"></i>Team tasks</a>
            <a class="nav-link" dmx-class:active="query.view == 'unassigned'" href="/tasks?view=unassigned"><i class="fas fa-user-slash me-2"></i>Unassigned</a>
            <a class="nav-link" dmx-class:active="query.view == 'all'" href="/tasks?view=all"><i class="fas fa-list me-2"></i>All tasks</a>
        </div>
    </div>

    <div class="col-12">
        <div class="card border-0 shadow-sm"><div class="card-body">
            <form method="get" action="/tasks" class="row g-3 align-items-end">
                <input type="hidden" name="view" dmx-bind:value="query.view.default('my')">
                <div class="col-12 col-lg-4"><label class="form-label" for="taskSearch">Search</label><input class="form-control" id="taskSearch" name="search" dmx-bind:value="query.search" placeholder="Task, event, phase or assignee"></div>
                <div class="col-12 col-md-6 col-lg-3"><label class="form-label" for="workflowFilter" dmx-text="scTerminology.data.query[0].workflowSingular">Event</label><select class="form-select" id="workflowFilter" name="workflowid" dmx-bind:options="scWorkflows.data.query" optiontext="workflowName" optionvalue="id" dmx-bind:value="query.workflowid"><option value="">All events</option></select></div>
                <div class="col-6 col-md-3 col-lg"><label class="form-label" for="statusFilter">Status</label><select class="form-select" id="statusFilter" name="status" dmx-bind:value="query.status.default('open')"><option value="open">Open</option><option value="all">All</option><option value="not_started">Not started</option><option value="in_progress">In progress</option><option value="waiting">Waiting</option><option value="complete">Complete</option><option value="skipped">Skipped</option><option value="cancelled">Cancelled</option></select></div>
                <div class="col-6 col-md-3 col-lg"><label class="form-label" for="priorityFilter">Priority</label><select class="form-select" id="priorityFilter" name="priority" dmx-bind:value="query.priority"><option value="">All</option><option value="urgent">Urgent</option><option value="high">High</option><option value="normal">Normal</option><option value="low">Low</option></select></div>
                <div class="col-6 col-md-3 col-lg"><label class="form-label" for="dueFilter">Due</label><select class="form-select" id="dueFilter" name="due" dmx-bind:value="query.due"><option value="">Any time</option><option value="overdue">Overdue</option><option value="today">Today</option><option value="soon">Next 7 days</option><option value="none">No due date</option></select></div>
                <div class="col-6 col-md-3 col-lg"><label class="form-label" for="blockedFilter">Dependencies</label><select class="form-select" id="blockedFilter" name="blocked" dmx-bind:value="query.blocked"><option value="">All</option><option value="ready">Ready</option><option value="blocked">Blocked</option></select></div>
                <div class="col-6 col-lg-auto d-grid"><button class="btn btn-primary" type="submit"><i class="fas fa-filter me-2"></i>Apply</button></div>
                <div class="col-6 col-lg-auto d-grid"><a class="btn btn-light" dmx-bind:href="'/tasks?view=' + query.view.default('my')">Clear</a></div>
            </form>
        </div></div>
    </div>

    <div class="col-12" is="dmx-repeat" id="repTaskEvents" dmx-bind:repeat="scWorkflows.data.query">
        <div class="card border-0 shadow-sm task-event-card" dmx-show="scTasks.data.query.where('workflowId', $value.id).count() > 0" dmx-bind:data-workflow-id="$value.id">
            <div class="card-header bg-white d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 py-3">
                <div>
                    <a class="h5 mb-1 text-decoration-none" dmx-bind:href="'/workflows/view?id=' + $value.id" dmx-text="$value.workflowName"></a>
                    <div class="small text-muted"><span dmx-text="$value.referenceCode"></span><span dmx-show="$value.referenceCode"> &middot; </span><span dmx-text="scTasks.data.query.where('workflowId', $value.id).count() + ' ' + scTerminology.data.query[0].taskPlural.lowercase()"></span></div>
                    <div is="dmx-repeat" dmx-bind:repeat="scNextTasks.data.query.where('workflowId', $value.id)" class="mt-2">
                        <div class="small"><span class="badge bg-success me-2">Next task</span><strong dmx-text="$value.taskName"></strong><span class="text-muted"> · </span><span class="text-muted" dmx-text="$value.stageName"></span><span class="text-muted ms-2" dmx-show="$value.dueDate" dmx-text="'Due ' + $value.dueDate.formatDate('dd MMM yyyy')"></span></div>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <span class="small js-event-save-message" aria-live="polite"></span>
                    <button type="button" class="btn btn-primary js-save-event-tasks" dmx-bind:data-workflow-id="$value.id" disabled><i class="fas fa-save me-2"></i>Save changes</button>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light"><tr><th dmx-text="scTerminology.data.query[0].taskSingular">Task</th><th dmx-text="scTerminology.data.query[0].stageSingular">Phase</th><th>Assigned to</th><th>Due</th><th>Priority</th><th>Dependencies</th><th>Status</th><th></th></tr></thead>
                    <tbody is="dmx-repeat" dmx-bind:repeat="scTasks.data.query.where('workflowId', $value.id)">
                        <tr>
                            <td><div class="fw-semibold" dmx-text="$value.taskName"></div><div class="small text-muted text-truncate" style="max-width:22rem" dmx-text="$value.description"></div></td>
                            <td><span dmx-text="$value.stageName"></span></td>
                            <td><span dmx-text="$value.assigneeName"></span><div class="small text-muted text-capitalize" dmx-text="$value.assigneeType"></div></td>
                            <td><span dmx-class:text-danger="$value.isOverdue == 1" dmx-class:fw-semibold="$value.isOverdue == 1" dmx-text="$value.dueDate.formatDate('dd MMM yyyy')"></span><div class="small text-danger" dmx-show="$value.isOverdue == 1">Overdue</div><span class="text-muted" dmx-show="!$value.dueDate">No date</span></td>
                            <td><span class="badge text-capitalize" dmx-class:bg-danger="$value.priority == 'urgent'" dmx-class:bg-warning="$value.priority == 'high'" dmx-class:text-dark="$value.priority == 'high'" dmx-class:bg-primary="$value.priority == 'normal'" dmx-class:bg-secondary="$value.priority == 'low'" dmx-text="$value.priority"></span></td>
                            <td><div class="text-danger small" dmx-show="$value.startBlockerCount > 0"><i class="fas fa-lock me-1"></i><span dmx-text="'Blocked by ' + $value.blockerNames"></span></div><div class="text-warning small" dmx-show="$value.startBlockerCount == 0 && $value.finishBlockerCount > 0"><i class="fas fa-link me-1"></i><span dmx-text="'Completion depends on ' + $value.blockerNames"></span></div><span class="badge bg-success" dmx-show="$value.startBlockerCount == 0 && $value.finishBlockerCount == 0">Ready</span></td>
                            <td><select class="form-select form-select-sm js-task-status" dmx-bind:data-task-id="$value.id" dmx-bind:data-workflow-id="$value.workflowId" dmx-bind:data-original-status="$value.status" dmx-bind:value="$value.status"><option value="not_started">Not started</option><option value="in_progress" dmx-bind:disabled="$value.startBlockerCount > 0">In progress</option><option value="waiting" dmx-bind:disabled="$value.startBlockerCount > 0">Waiting</option><option value="complete" dmx-bind:disabled="$value.startBlockerCount > 0 || $value.finishBlockerCount > 0">Complete</option><option value="skipped">Skipped</option><option value="cancelled">Cancelled</option></select></td>
                            <td><div class="btn-group"><a class="btn btn-sm btn-outline-secondary" dmx-bind:href="'/tasks/edit?id=' + $value.id" title="Edit task"><i class="fas fa-pen"></i></a><a class="btn btn-sm btn-outline-secondary" dmx-bind:href="'/workflows/view?id=' + $value.workflowId" title="Open event"><i class="fas fa-external-link-alt"></i></a></div></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-12"><div class="card border-0 shadow-sm"><div class="text-center text-muted py-5" dmx-show="!scTasks.state.executing && scTasks.data.query.count() == 0"><i class="fas fa-check-circle fa-2x mb-3 text-success"></i><div class="fw-semibold">Nothing needs attention in this view.</div><div class="small">Try changing the filters or selecting another inbox.</div></div></div></div>
</div>

<style>
    .js-task-status.is-changed { border-color: var(--bs-warning); box-shadow: 0 0 0 .2rem rgba(255, 193, 7, .2); }
</style>
<script>
document.addEventListener('change', function (event) {
    if (!event.target.matches('.js-task-status')) return;
    event.target.classList.toggle('is-changed', event.target.value !== event.target.dataset.originalStatus);
    updateEventSaveButton(event.target.closest('.task-event-card'));
});

document.addEventListener('click', async function (event) {
    const button = event.target.closest('.js-save-event-tasks');
    if (!button) return;
    const card = button.closest('.task-event-card');
    const changed = Array.from(card.querySelectorAll('.js-task-status')).filter(function (select) {
        return select.value !== select.dataset.originalStatus;
    });
    if (!changed.length) return;

    const message = card.querySelector('.js-event-save-message');
    const csrf = document.querySelector('#taskCsrfSource input');
    const originalHtml = button.innerHTML;
    button.disabled = true;
    button.innerHTML = '<span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>Saving...';
    message.className = 'small text-muted js-event-save-message';
    message.textContent = '';

    let saved = 0;
    try {
        for (const select of changed) {
            const data = new FormData();
            data.append('id', select.dataset.taskId);
            data.append('workflowId', select.dataset.workflowId);
            data.append('status', select.value);
            if (csrf) data.append(csrf.name, csrf.value);
            const response = await fetch('/api/tasks/update_status', { method: 'POST', body: data, credentials: 'same-origin' });
            if (!response.ok) {
                let apiError = null;
                try { apiError = await response.json(); } catch (parseError) { apiError = null; }
                throw new Error(apiError && apiError.message ? apiError.message : 'A task could not be saved. Check its permissions and dependencies, then try again.');
            }
            select.dataset.originalStatus = select.value;
            select.classList.remove('is-changed');
            saved++;
        }
        message.className = 'small text-success js-event-save-message';
        message.textContent = saved === 1 ? '1 change saved' : saved + ' changes saved';
        setTimeout(function () { window.location.reload(); }, 600);
    } catch (error) {
        message.className = 'small text-danger js-event-save-message';
        message.textContent = error.message;
    } finally {
        button.innerHTML = originalHtml;
        updateEventSaveButton(card);
    }
});

function updateEventSaveButton(card) {
    if (!card) return;
    const hasChanges = Array.from(card.querySelectorAll('.js-task-status')).some(function (select) {
        return select.value !== select.dataset.originalStatus;
    });
    const button = card.querySelector('.js-save-event-tasks');
    if (button) button.disabled = !hasChanges;
}
</script>
<meta name="ac:route" content="/tasks">

<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="edit_task" appConnect="local" components="{dmxStateManagement:{}}" -->
<dmx-serverconnect id="scTask" url="/api/tasks/get" dmx-param:id="query.id"></dmx-serverconnect>
<dmx-serverconnect id="scAssignees" url="/api/tasks/assignee_options"></dmx-serverconnect>

<div class="row g-4">
    <div class="col-12"><div class="d-flex justify-content-between align-items-center gap-3"><div><h1 class="mb-1">Edit Task</h1><p class="text-muted mb-0"><span dmx-text="scTask.data.query[0].workflowName"></span><span> · </span><span dmx-text="scTask.data.query[0].stageName"></span></p></div><a class="btn btn-outline-secondary" href="/tasks">Back to tasks</a></div></div>
    <div class="col-12 col-xl-8"><div class="card border-0 shadow-sm"><div class="card-header bg-white"><h2 class="h5 mb-0">Task details</h2></div><div class="card-body"><form method="post" action="/api/tasks/update"><%- _csrfInput() %><input type="hidden" name="id" dmx-bind:value="scTask.data.query[0].id"><div class="mb-3"><label class="form-label">Task name</label><input class="form-control" name="taskName" required dmx-bind:value="scTask.data.query[0].taskName"></div><div class="mb-3"><label class="form-label">Description</label><textarea class="form-control" name="description" rows="4" dmx-bind:value="scTask.data.query[0].description"></textarea></div><div class="row g-3"><div class="col-md-6"><label class="form-label">Status</label><select class="form-select" name="status" dmx-bind:value="scTask.data.query[0].status"><option value="not_started">Not started</option><option value="in_progress">In progress</option><option value="waiting">Waiting</option><option value="complete">Complete</option><option value="skipped">Skipped</option><option value="cancelled">Cancelled</option><option value="overdue">Overdue</option></select></div><div class="col-md-3"><label class="form-label">Priority</label><select class="form-select" name="priority" dmx-bind:value="scTask.data.query[0].priority"><option value="low">Low</option><option value="normal">Normal</option><option value="high">High</option><option value="urgent">Urgent</option></select></div><div class="col-md-3"><label class="form-label">Required</label><select class="form-select" name="isRequired" dmx-bind:value="scTask.data.query[0].isRequired"><option value="1">Yes</option><option value="0">No</option></select></div><div class="col-md-6"><label class="form-label">Assigned to</label><select class="form-select" name="assignment" dmx-bind:options="scAssignees.data.query" optiontext="assignmentLabel" optionvalue="assignmentKey" dmx-bind:value="scTask.data.query[0].assignmentKey"></select></div><div class="col-md-6"><label class="form-label">Due date and time</label><input class="form-control" name="dueDate" type="datetime-local" dmx-bind:value="scTask.data.query[0].dueDate.formatDate('yyyy-MM-ddTHH:mm')"></div></div><div class="d-flex gap-2 mt-4"><button class="btn btn-primary" type="submit">Update Task</button><a class="btn btn-light" href="/tasks">Cancel</a><a class="btn btn-outline-secondary ms-auto" dmx-bind:href="'/workflows/view?id=' + scTask.data.query[0].workflowId">Open workflow</a></div></form></div></div></div>
</div><meta name="ac:route" content="/tasks/edit">

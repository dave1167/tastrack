<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="activity_log" appConnect="local" components="{dmxStateManagement:{}}" -->
<dmx-serverconnect id="scActivityLog" url="/api/activity/log" dmx-param:search="query.search" dmx-param:category="query.category" dmx-param:datefrom="query.datefrom" dmx-param:dateto="query.dateto"></dmx-serverconnect>

<div class="row g-4">
    <div class="col-12"><div class="d-flex justify-content-between align-items-center"><div><h1 class="mb-1">Activity Log</h1><p class="text-muted mb-0">Tenant audit history for events, tasks, locations and administration.</p></div><span class="badge rounded-pill bg-primary" dmx-text="scActivityLog.data.query.count() + ' entries'"></span></div></div>
    <div class="col-12"><div class="card border-0 shadow-sm"><div class="card-body"><form method="get" action="/activity-log" class="row g-3 align-items-end"><div class="col-12 col-lg-4"><label class="form-label">Search</label><input class="form-control" name="search" dmx-bind:value="query.search" placeholder="Person, action, event or task"></div><div class="col-6 col-lg-2"><label class="form-label">Category</label><select class="form-select" name="category" dmx-bind:value="query.category"><option value="">All categories</option><option value="locations">Locations</option><option value="workflow">Workflows</option><option value="task">Tasks</option><option value="contact">Contacts</option><option value="user">Users</option></select></div><div class="col-6 col-lg-2"><label class="form-label">From</label><input class="form-control" name="datefrom" type="date" dmx-bind:value="query.datefrom"></div><div class="col-6 col-lg-2"><label class="form-label">To</label><input class="form-control" name="dateto" type="date" dmx-bind:value="query.dateto"></div><div class="col-6 col-lg-2 d-flex gap-2"><button class="btn btn-primary flex-fill" type="submit">Filter</button><a class="btn btn-light" href="/activity-log">Clear</a></div></form></div></div></div>
    <div class="col-12"><div class="card border-0 shadow-sm"><div class="card-body p-0"><div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead class="table-light"><tr><th>Date and time</th><th>Person</th><th>Activity</th><th>Related record</th><th class="text-end">Details</th></tr></thead><tbody is="dmx-repeat" dmx-bind:repeat="scActivityLog.data.query"><tr><td class="text-nowrap"><div dmx-text="createdDate.formatDate('dd MMM yyyy')"></div><div class="small text-muted" dmx-text="createdDate.formatDate('HH:mm:ss')"></div></td><td dmx-text="actorName"></td><td><div class="fw-semibold" dmx-text="summary"></div><div class="small text-muted"><span class="text-capitalize" dmx-text="activityCategory"></span><span> · </span><span dmx-text="actionType"></span></div></td><td><a dmx-show="workflowId" dmx-bind:href="'/workflows/view?id=' + workflowId" dmx-text="workflowName || 'Open event'"></a><div dmx-show="taskId" class="small" dmx-text="taskName"></div><span dmx-show="!workflowId && !taskId" class="text-capitalize" dmx-text="entityType + (entityId ? ' #' + entityId : '')"></span></td><td class="text-end"><button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" dmx-bind:data-bs-target="'#activityDetails' + id">View</button></td></tr><tr class="collapse" dmx-bind:id="'activityDetails' + id"><td colspan="5" class="bg-light"><div class="row g-3 p-2"><div class="col-md-6"><div class="small fw-semibold text-uppercase text-muted mb-1">Before</div><pre class="small bg-white border rounded p-2 mb-0 text-wrap" dmx-text="beforeJson || 'No previous value recorded'"></pre></div><div class="col-md-6"><div class="small fw-semibold text-uppercase text-muted mb-1">After</div><pre class="small bg-white border rounded p-2 mb-0 text-wrap" dmx-text="afterJson || 'No new value recorded'"></pre></div></div></td></tr></tbody></table></div><div class="text-center text-muted py-5" dmx-show="!scActivityLog.state.executing && scActivityLog.data.query.count() == 0"><i class="fas fa-history fa-2x mb-3"></i><h2 class="h6">No activity found</h2><p class="small mb-0">Try changing or clearing the filters.</p></div></div></div></div>
</div>
<script src="/js/activity-log-terminology.js"></script>
<meta name="ac:route" content="/activity-log">

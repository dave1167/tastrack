<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="team_roles" appConnect="local" components="{dmxBootstrap5TableGenerator:{},dmxStateManagement:{},dmxBrowser:{},dmxBootstrap5Modal:{}}" -->
<dmx-query-manager id="query1"></dmx-query-manager>
<dmx-browser id="browser1"></dmx-browser>

<dmx-serverconnect id="scTeams" url="/api/teams/list_teams"></dmx-serverconnect>
<dmx-serverconnect id="scTeamRoles" url="/api/teams/list_team_roles" noload="true"></dmx-serverconnect>

<dmx-value id="varSelectedTeam"></dmx-value>
<dmx-value id="varDeleteRoleId"></dmx-value>
<dmx-value id="varDeleteRoleName"></dmx-value>

<div class="modal fade" id="modDelconfirm" is="dmx-bs5-modal" tabindex="-1" aria-labelledby="modDelconfirmTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">

            <div class="modal-header bg-danger text-white">
                <div class="d-flex align-items-center gap-2">
                    <i class="fas fa-exclamation-triangle fa-lg"></i>
                    <h5 class="modal-title mb-0" id="modDelconfirmTitle">Delete team role?</h5>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form id="frmDeleteTeamRole" is="dmx-serverconnect-form" method="post" action="/api/teams/delete_team_role" dmx-on:success="modDelconfirm.hide(); scTeamRoles.load({teamid: varSelectedTeam.value})">

                <div class="modal-body p-4">

                    <input type="hidden" name="roleId" dmx-bind:value="varDeleteRoleId.value">

                    <div class="alert alert-warning d-flex align-items-start gap-2" dmx-if="frmDeleteTeamRole.lastError.response.message">
                        <i class="fas fa-exclamation-triangle mt-1"></i>
                        <div dmx-text="frmDeleteTeamRole.lastError.response.message"></div>
                    </div>

                    <div class="d-flex gap-3">
                        <div class="flex-shrink-0">
                            <div class="rounded-circle bg-danger-subtle text-danger d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                                <i class="fas fa-trash-alt fa-lg"></i>
                            </div>
                        </div>

                        <div>
                            <h6 class="mb-2">You are about to delete this team role:</h6>

                            <div class="border rounded bg-light p-3 mb-3">
                                <div class="fw-semibold" dmx-text="varDeleteRoleName.value"></div>
                            </div>

                            <p class="text-muted mb-0">
                                This action may affect users assigned to this role. Please only continue if you are sure this role is no longer required.
                            </p>
                        </div>
                    </div>

                </div>

                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <button type="submit" class="btn btn-danger" dmx-bind:disabled="frmDeleteTeamRole.state.executing">
                        <span dmx-show="!frmDeleteTeamRole.state.executing">
                            <i class="fas fa-trash-alt me-1"></i> Delete role
                        </span>
                        <span style="display: none;" dmx-show="frmDeleteTeamRole.state.executing">
                            Deleting...
                        </span>
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-12">
        <h1 class="mb-1">Team Roles</h1>
        <p class="text-muted mb-0">Create roles that belong inside a team, such as Finance Assistant within Finance.</p>
    </div>

    <div class="col-12 col-xl-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h2 class="h5 mb-0">Add team role</h2>
            </div>

            <div class="card-body">
                <form id="frmTeamRole" is="dmx-serverconnect-form" method="post" action="/api/teams/add_team_role" dmx-on:success="scTeamRoles.load({teamid: varSelectedTeam.value}); inp_teamRoleName.setValue('')">

                    <div class="mb-3">
                        <label for="inp_teamId" class="form-label">Team</label>

                        <select id="inp_teamId" name="teamId" class="form-select" required dmx-bind:options="scTeams.data.query" optiontext="teamName" optionvalue="id" dmx-on:changed="varSelectedTeam.setValue(value); scTeamRoles.load({teamid: value})">
                            <option value="">Select team</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label for="inp_teamRoleName" class="form-label">Role name</label>
                        <input id="inp_teamRoleName" name="teamRoleName" type="text" class="form-control" placeholder="Finance Assistant" required>
                    </div>

                    <button type="submit" class="btn btn-primary" dmx-bind:disabled="frmTeamRole.state.executing || !varSelectedTeam.value">
                        <span dmx-show="!frmTeamRole.state.executing">Save Team Role</span>
                        <span style="display: none;" dmx-show="frmTeamRole.state.executing">Saving...</span>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex align-items-center justify-content-between">
                <h2 class="h5 mb-0">Existing team roles</h2>
                <span class="text-muted small" dmx-show="varSelectedTeam.value">
                    Showing roles for selected team
                </span>
            </div>

            <div class="card-body">
                <div class="alert alert-info mb-0" dmx-show="!varSelectedTeam.value">
                    Select a team to view its roles.
                </div>

                <div class="text-muted small mb-3" dmx-show="varSelectedTeam.value && scTeamRoles.state.executing">
                    Loading team roles...
                </div>

                <div class="table-responsive" dmx-show="varSelectedTeam.value && !scTeamRoles.state.executing">
                    <table class="table table-striped table-bordered table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Role</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>

                        <tbody is="dmx-repeat" dmx-generator="bs5table" dmx-bind:repeat="scTeamRoles.data.query" id="tableRepeat1">
                            <tr>
                                <td dmx-text="roleDesc"></td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-outline-danger btn-sm" title="Delete role" dmx-on:click="varDeleteRoleId.setValue(id); varDeleteRoleName.setValue(roleDesc); modDelconfirm.show()">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="text-muted small mt-3" dmx-show="varSelectedTeam.value && scTeamRoles.data.query && scTeamRoles.data.query.count() == 0 && !scTeamRoles.state.executing">
                    No roles have been created for this team yet.
                </div>
            </div>
        </div>
    </div>
</div>

<meta name="ac:route" content="/teams/team_roles">
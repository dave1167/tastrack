<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="delete_team" appConnect="local" components="{dmxBootstrap5TableGenerator:{},dmxStateManagement:{}}" -->
<dmx-serverconnect id="scTeam" url="/api/teams/get_team" dmx-param:id="query.id"></dmx-serverconnect>

<div class="row g-4">
    <div class="col-12">
        <div class="d-flex align-items-center justify-content-between gap-3">
            <div>
                <h1 class="mb-1">Delete Team</h1>
                <p class="text-muted mb-0">Review the team before deleting it.</p>
            </div>
            <a class="btn btn-outline-secondary" href="/teams/teams">Back to teams</a>
        </div>
    </div>

    <div class="col-12 col-xl-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h2 class="h5 mb-0">Confirm deletion</h2>
            </div>
            <div class="card-body">
                <div class="alert alert-warning mb-4" role="alert">
                    This will make the team inactive. Existing linked tasks, members, and workflows will remain intact.
                </div>

                <dl class="row mb-4">
                    <dt class="col-sm-4">Team</dt>
                    <dd class="col-sm-8" dmx-text="scTeam.data.query[0].teamName"></dd>

                    <dt class="col-sm-4">Description</dt>
                    <dd class="col-sm-8" dmx-text="scTeam.data.query[0].description"></dd>
                </dl>

                <form method="post" dmx-bind:action="'/api/teams/delete_team?id=' + query.id">
                    <%- _csrfInput() %>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">Deactivate Team</button>
                        <a class="btn btn-light" href="/teams/teams">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<meta name="ac:route" content="/teams/delete_team">

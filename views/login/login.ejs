<!-- Wappler include head-page="layouts/main" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="login" appConnect="local" components="{dmxBootstrap5Alert:{}}" -->
<meta name="ac:route" content="/login/login">

<section class="login-page py-5 py-lg-0">
    <div class="container">
        <div class="row min-vh-100 align-items-center justify-content-center">
            <div class="col-12 col-md-10 col-lg-8 col-xl-9">
                <div class="card border-0 shadow-lg overflow-hidden login-shell">
                    <div class="row g-0">
                        <div class="col-lg-5 d-none d-lg-flex">
                            <div class="login-brand-panel p-5 w-100 d-flex flex-column justify-content-between">
                                <div><img src="/uploads/tastrack_logo.png" alt="TasTrack" class="img-fluid login-brand-logo"></div>
                                <div class="text-white">
                                    <h2 class="h3 fw-bold mb-3">Welcome back</h2>
                                    <p class="mb-0 text-white-50">Sign in to continue tracking tasks, deadlines, and team progress.</p>
                                </div>
                                <div class="text-white-50 small">Stay focused. Stay organized.</div>
                            </div>
                        </div>
                        <div class="col-lg-7 bg-body">
                            <div class="p-4 p-md-5">
                                <div class="mb-4">
                                    <h1 class="h4 mb-2">Sign in</h1>
                                    <p class="text-body-secondary mb-0">Use your account credentials to access your workspace.</p>
                                </div>

                                <form is="dmx-serverconnect-form" id="login_form" class="needs-validation" method="post" action="/api/auth/login" novalidate>
                                    <div class="alert alert-danger" role="alert" dmx-show="login_form.state.lastError">
                                        <i class="fas fa-exclamation-circle me-2"></i>
                                        <span dmx-text="login_form.lastError.message.default('Login failed. Please check your credentials and try again.')"></span>
                                    </div>

                                    <div class="form-group mb-3">
                                        <label for="inp_username" class="form-label">Username</label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="fas fa-user"></i></span>
                                            <input type="text" class="form-control" id="inp_username" name="username" placeholder="Enter your username" required data-msg-required="Please enter your username">
                                        </div>
                                    </div>

                                    <div class="form-group mb-3">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <label for="inp_password" class="form-label mb-0">Password</label>
                                            <a href="/" class="small text-decoration-none">Need help?</a>
                                        </div>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="fas fa-lock"></i></span>
                                            <input type="password" class="form-control" id="inp_password" name="password" placeholder="Enter your password" required data-msg-required="Please enter your password">
                                        </div>
                                    </div>

                                    <div class="form-group mb-4">
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input" id="inp_remember" name="remember" value="1">
                                            <label class="form-check-label" for="inp_remember">Remember me on this device</label>
                                        </div>
                                    </div>

                                    <div class="d-grid">
                                        <button type="submit" class="btn btn-primary btn-lg login-submit-btn d-inline-flex align-items-center justify-content-center gap-2" dmx-bind:disabled="login_form.state.executing"><span class="spinner-border spinner-border-sm" role="status" aria-hidden="true" dmx-show="login_form.state.executing"></span><span dmx-show="!login_form.state.executing">Sign in</span><span dmx-show="login_form.state.executing">Signing in...</span></button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
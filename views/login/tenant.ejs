<!-- Wappler include head-page="layouts/main" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="login_tenant" appConnect="local" components="{dmxBootstrap5Alert:{},dmxBrowser:{}}" -->
<div is="dmx-browser" id="browser1"></div>
<dmx-serverconnect id="scTenantOptions" url="/api/login/tenant_options"></dmx-serverconnect>
<meta name="ac:route" content="/login/tenant">

<section class="login-page py-5 py-lg-0">
    <div class="container">
        <div class="row min-vh-100 align-items-center justify-content-center">
            <div class="col-12 col-md-10 col-lg-8 col-xl-9">
                <div class="card border-0 shadow-lg overflow-hidden login-shell">
                    <div class="row g-0">
                        <div class="col-lg-5 d-none d-lg-flex">
                            <div class="login-brand-panel p-5 w-100 d-flex flex-column justify-content-between">
                                <div><img src="/uploads/tastrack_logo.png" alt="TasTrack" class="img-fluid login-brand-logo"></div>
                                <div class="text-white">
                                    <h2 class="h3 fw-bold mb-3">Welcome back</h2>
                                    <p class="mb-0 text-white-50">Sign in to continue tracking tasks, deadlines, and team progress.</p>
                                </div>
                                <div class="text-white-50 small">Stay focused. Stay organized.</div>
                            </div>
                        </div>
                        <div class="col-lg-7 bg-body">
                            <div class="p-4 p-md-5">
                                <div class="mb-4">
                                    <h1 class="h4 mb-2">Choose your tenant</h1>
                                    <p class="text-body-secondary mb-0">You are a member of multiple tenants. Select the workspace you want to use.</p>
                                </div>

                                <form id="tenant_form" class="needs-validation" method="post" action="/api/login/select_tenant" novalidate>
                                    <div class="alert alert-danger" role="alert" dmx-show="tenant_form.state.lastError">
                                        <i class="fas fa-exclamation-circle me-2"></i>
                                        <span dmx-text="tenant_form.lastError.message.default('Unable to continue. Please select a tenant and try again.')"></span>
                                    </div>

                                    <div class="form-group mb-4">
                                        <label for="inp_tenant" class="form-label">Tenant</label>
                                        <div class="input-group">
                                            <span class="input-group-text"><i class="fas fa-building"></i></span>
                                            <select id="inp_tenant" name="tenant_id" class="form-select" required="" data-msg-required="Please select a tenant" dmx-bind:options="scTenantOptions.data.query" optiontext="tenantName" optionvalue="tenantId">
                                                <option selected="" value="">Select a tenant</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="d-grid">
                                        <button type="submit" class="btn btn-primary btn-lg login-submit-btn d-inline-flex align-items-center justify-content-center gap-2">
                                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true" dmx-show="tenant_form.state.executing"></span>
                                            <span dmx-show="!tenant_form.state.executing">Continue</span>
                                            <span dmx-show="tenant_form.state.executing">Continuing...</span>
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
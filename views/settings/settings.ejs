<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="organisation_settings" appConnect="local" -->
<div class="row g-4">
    <div class="col-12"><div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3"><div><h1 class="mb-1">Organisation settings</h1><p class="text-muted mb-0">Use the language your organisation uses every day.</p></div><span class="badge rounded-pill bg-success px-3 py-2" dmx-show="query.saved == 1"><i class="fas fa-check me-2"></i>Terminology saved</span></div></div>
    <div class="col-12 col-xl-8"><div class="card border-0 shadow-sm"><div class="card-header bg-white py-3"><h2 class="h5 mb-1">Terminology</h2><p class="text-muted small mb-0">These labels are used in navigation, headings and forms for this organisation.</p></div><div class="card-body p-4">
        <form method="post" action="/api/settings/update_terminology"><%- _csrfInput() %><input type="hidden" name="tenantId" dmx-bind:value="scWelcome.data.TENANT_ID">
            <div class="row g-3 align-items-end mb-3"><div class="col-md-4"><div class="fw-semibold">Workflow</div><div class="small text-muted">For example Event, Show or Project</div></div><div class="col-md-4"><label class="form-label" for="workflowSingular">Singular</label><input class="form-control" id="workflowSingular" name="workflowSingular" maxlength="100" required dmx-bind:value="scTerminology.data.query[0].workflowSingular"></div><div class="col-md-4"><label class="form-label" for="workflowPlural">Plural</label><input class="form-control" id="workflowPlural" name="workflowPlural" maxlength="100" required dmx-bind:value="scTerminology.data.query[0].workflowPlural"></div></div><hr>
            <div class="row g-3 align-items-end my-3"><div class="col-md-4"><div class="fw-semibold">Stage</div><div class="small text-muted">The sections within a workflow</div></div><div class="col-md-4"><label class="form-label" for="stageSingular">Singular</label><input class="form-control" id="stageSingular" name="stageSingular" maxlength="100" required dmx-bind:value="scTerminology.data.query[0].stageSingular"></div><div class="col-md-4"><label class="form-label" for="stagePlural">Plural</label><input class="form-control" id="stagePlural" name="stagePlural" maxlength="100" required dmx-bind:value="scTerminology.data.query[0].stagePlural"></div></div><hr>
            <div class="row g-3 align-items-end my-3"><div class="col-md-4"><div class="fw-semibold">Task</div><div class="small text-muted">The individual pieces of work</div></div><div class="col-md-4"><label class="form-label" for="taskSingular">Singular</label><input class="form-control" id="taskSingular" name="taskSingular" maxlength="100" required dmx-bind:value="scTerminology.data.query[0].taskSingular"></div><div class="col-md-4"><label class="form-label" for="taskPlural">Plural</label><input class="form-control" id="taskPlural" name="taskPlural" maxlength="100" required dmx-bind:value="scTerminology.data.query[0].taskPlural"></div></div><hr>
            <div class="row g-3 align-items-end my-3"><div class="col-md-4"><div class="fw-semibold">Location</div><div class="small text-muted">For example Venue, Site or Building</div></div><div class="col-md-4"><label class="form-label" for="locationSingular">Singular</label><input class="form-control" id="locationSingular" name="locationSingular" maxlength="100" required dmx-bind:value="scTerminology.data.query[0].locationSingular"></div><div class="col-md-4"><label class="form-label" for="locationPlural">Plural</label><input class="form-control" id="locationPlural" name="locationPlural" maxlength="100" required dmx-bind:value="scTerminology.data.query[0].locationPlural"></div></div><hr>
            <div class="row g-3 align-items-end my-3"><div class="col-md-4"><div class="fw-semibold">Space</div><div class="small text-muted">For example Room, Auditorium or Hall</div></div><div class="col-md-4"><label class="form-label" for="spaceSingular">Singular</label><input class="form-control" id="spaceSingular" name="spaceSingular" maxlength="100" required dmx-bind:value="scTerminology.data.query[0].spaceSingular"></div><div class="col-md-4"><label class="form-label" for="spacePlural">Plural</label><input class="form-control" id="spacePlural" name="spacePlural" maxlength="100" required dmx-bind:value="scTerminology.data.query[0].spacePlural"></div></div><hr>
            <div class="row g-3 align-items-end mt-3"><div class="col-md-4"><div class="fw-semibold">Configuration</div><div class="small text-muted">For example Layout, Setup or Seating plan</div></div><div class="col-md-4"><label class="form-label" for="configurationSingular">Singular</label><input class="form-control" id="configurationSingular" name="configurationSingular" maxlength="100" required dmx-bind:value="scTerminology.data.query[0].configurationSingular"></div><div class="col-md-4"><label class="form-label" for="configurationPlural">Plural</label><input class="form-control" id="configurationPlural" name="configurationPlural" maxlength="100" required dmx-bind:value="scTerminology.data.query[0].configurationPlural"></div></div>
            <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top"><a class="btn btn-light" href="/">Cancel</a><button class="btn btn-primary" type="submit"><i class="fas fa-save me-2"></i>Save terminology</button></div>
        </form>
    </div></div></div>
    <div class="col-12 col-xl-4"><div class="card border-0 shadow-sm bg-light"><div class="card-body p-4"><h2 class="h6">Example</h2><p class="text-muted small mb-3">For an events organisation you might use:</p><div class="d-flex flex-wrap gap-2"><span class="badge bg-white text-dark border">Event / Events</span><span class="badge bg-white text-dark border">Stage / Stages</span><span class="badge bg-white text-dark border">Task / Tasks</span></div></div></div></div>
</div>
<meta name="ac:route" content="/settings">

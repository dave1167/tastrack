<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="edit_user" appConnect="local" components="{dmxBootstrap5TableGenerator:{},dmxStateManagement:{},dmxBrowser:{}}" -->
<dmx-query-manager id="query1"></dmx-query-manager>
<dmx-browser id="browser1"></dmx-browser>

<dmx-serverconnect id="scRoles" url="/api/roles/list_roles"></dmx-serverconnect>
<dmx-serverconnect id="scTeams" url="/api/teams/list_teams"></dmx-serverconnect>
<dmx-serverconnect id="scTeamRoles" url="/api/teams/get_team_role" noload="true"></dmx-serverconnect>
<dmx-serverconnect id="scSessContext" url="/api/security/sessionContext"></dmx-serverconnect>

<dmx-serverconnect id="scGetUser" url="/api/users/getUser" dmx-param:userid="query1.data.userid" dmx-on:success="scTeamRoles.load({teamid: scGetUser.data.query[0].teamId})">
</dmx-serverconnect>

<div class="row g-4">
    <div class="col-12">
        <div class="d-flex align-items-center justify-content-between gap-3">
            <div>
                <h1 class="mb-1">Edit User</h1>
                <p class="text-muted mb-0">Update the user details, access level, team and team member role for the current tenant.</p>
            </div>
            <a class="btn btn-outline-secondary" href="/users/all_users">Back to users</a>
        </div>
    </div>

    <div class="col-12 col-xl-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h2 class="h5 mb-0">User details</h2>
            </div>

            <div class="card-body">

                <div class="alert alert-info" dmx-show="scGetUser.state.executing">
                    Loading user details...
                </div>

                <div class="alert alert-danger" dmx-if="frmEditUser.lastError.response.message">
                    <span dmx-text="frmEditUser.lastError.response.message"></span>
                </div>

                <form id="frmEditUser" is="dmx-serverconnect-form" method="post" action="/api/users/editUser" dmx-on:success="browser1.goto('/users/all_users')">

                    <input id="hidUserId" name="userId" type="hidden" dmx-bind:value="scGetUser.data.query[0].userId">
                    <input id="hidTenantUserRoleId" name="tenantUserRoleId" type="hidden" dmx-bind:value="scGetUser.data.query[0].tenantUserRoleId">
                    <input id="hidTeamMemberId" name="teamMemberId" type="hidden" dmx-bind:value="scGetUser.data.query[0].teamMemberId">

                    <div class="row g-3">

                        <div class="col-12">
                            <div class="form-floating">
                                <input id="inp_email" name="email" type="email" class="form-control" placeholder="Email" required="" dmx-bind:value="scGetUser.data.query[0].email" dmx-class:is-invalid="frmEditUser.lastError.response.form.email">
                                <label for="inp_email">Email</label>
                            </div>

                            <%- await include('../partials/form_field_error', {
                                formId: 'frmEditUser',
                                fieldName: 'email'
                            }) %>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="form-floating">
                                <input id="inp_fName" name="fName" type="text" class="form-control" placeholder="First name" dmx-bind:value="scGetUser.data.query[0].fName">
                                <label for="inp_fName">First name</label>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="form-floating">
                                <input id="inp_lName" name="lName" type="text" class="form-control" placeholder="Last name" dmx-bind:value="scGetUser.data.query[0].lName">
                                <label for="inp_lName">Last name</label>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="form-floating">
                                <input id="inp_displayName" name="displayName" type="text" class="form-control" placeholder="Display name" required dmx-bind:value="scGetUser.data.query[0].displayName">
                                <label for="inp_displayName">Display name</label>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="form-floating">
                                <select id="inp_isActive" name="isActive" class="form-select" required dmx-bind:value="scGetUser.data.query[0].userActive">
                                    <option value="1">Active</option>
                                    <option value="0">Inactive</option>
                                </select>
                                <label for="inp_isActive">User status</label>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="form-floating">
                                <select id="inp_roleId" name="roleId" class="form-select" required dmx-bind:options="scRoles.data.query" optiontext="roleName" optionvalue="id" dmx-bind:value="scGetUser.data.query[0].roleId">
                                    <option value="">Select User Access Level</option>
                                </select>
                                <label for="inp_roleId">User Access</label>
                            </div>

                            <input id="hidRoleId" name="hidRoleId" type="hidden" dmx-bind:value="inp_roleId.value">
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="form-floating">
                                <select id="inp_teamId" name="teamId" class="form-select" required dmx-bind:options="scTeams.data.query" optiontext="teamName" optionvalue="id" dmx-bind:value="scGetUser.data.query[0].teamId" dmx-on:changed="scTeamRoles.load({teamid: value})">
                                    <option value="">Select team</option>
                                </select>
                                <label for="inp_teamId">Team</label>
                            </div>

                            <input id="hidTeamId" name="hidTeamId" type="hidden" dmx-bind:value="inp_teamId.value">
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="form-floating">
                                <select id="inp_teamRole" name="teamRole" class="form-select" required dmx-bind:options="scTeamRoles.data.qryTeamRoles" optiontext="roleDesc" optionvalue="id" dmx-bind:value="scGetUser.data.query[0].teamRoleId">
                                    <option value="">Select Role</option>
                                </select>
                                <label for="inp_teamRole">Team member Role</label>
                            </div>

                            <input id="hidTeamRole" name="hidTeamRole" type="hidden" dmx-bind:value="inp_teamRole.value">
                        </div>

                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary" dmx-bind:disabled="frmEditUser.state.executing || scGetUser.state.executing">
                            <span dmx-show="!frmEditUser.state.executing">Save Changes</span>
                            <span style="display: none;" dmx-show="frmEditUser.state.executing">Saving...</span>
                        </button>

                        <a class="btn btn-light" href="/users/all_users">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<meta name="ac:route" content="/users/edit_user">

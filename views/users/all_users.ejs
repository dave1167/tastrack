<!-- Wappler include head-page="layouts/main_shell" fontawesome_5="cdn" bootstrap5="local" is="dmx-app" id="all_users" appConnect="local" components="{dmxBootstrap5TableGenerator:{},dmxStateManagement:{},dmxBootstrap5Tooltips:{}}" -->
<dmx-query-manager id="query1"></dmx-query-manager>
<dmx-serverconnect id="scListAllUsers" url="/api/users/list"></dmx-serverconnect>

<div class="row g-4">
    <div class="col-12">
        <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3">
            <div>
                <h1 class="mb-1">Users</h1>
                <p class="text-muted mb-0">Manage user access, team membership and account status for the current tenant.</p>
            </div>

            <a class="btn btn-primary align-self-start align-self-sm-center" href="/users/create_user">
                <i class="fas fa-user-plus me-2"></i>Add user
            </a>
        </div>
    </div>

    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex align-items-center justify-content-between gap-3 py-3">
                <h2 class="h5 mb-0">All users</h2>

                <span class="badge rounded-pill bg-primary" dmx-show="!scListAllUsers.state.executing" dmx-text="scListAllUsers.data.query.count() + (scListAllUsers.data.query.count() == 1 ? ' user' : ' users')"></span>
            </div>

            <div class="card-body">
                <div class="text-muted small" dmx-show="scListAllUsers.state.executing">
                    <i class="fas fa-circle-notch fa-spin me-2"></i>Loading users...
                </div>

                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="sorting" dmx-on:click="query1.set('sort','displayName');query1.set('dir',query1.data.dir == 'desc' ? 'asc' : 'desc')" dmx-class:sorting_asc="query1.data.sort == 'displayName' && query1.data.dir == 'asc'" dmx-class:sorting_desc="query1.data.sort == 'displayName' && query1.data.dir == 'desc'">User</th>
                                <th class="sorting" dmx-on:click="query1.set('sort','accessRole');query1.set('dir',query1.data.dir == 'desc' ? 'asc' : 'desc')" dmx-class:sorting_asc="query1.data.sort == 'accessRole' && query1.data.dir == 'asc'" dmx-class:sorting_desc="query1.data.sort == 'accessRole' && query1.data.dir == 'desc'">Access level</th>
                                <th class="sorting" dmx-on:click="query1.set('sort','teamName');query1.set('dir',query1.data.dir == 'desc' ? 'asc' : 'desc')" dmx-class:sorting_asc="query1.data.sort == 'teamName' && query1.data.dir == 'asc'" dmx-class:sorting_desc="query1.data.sort == 'teamName' && query1.data.dir == 'desc'">Team</th>
                                <th class="sorting" dmx-on:click="query1.set('sort','teamRoleDesc');query1.set('dir',query1.data.dir == 'desc' ? 'asc' : 'desc')" dmx-class:sorting_asc="query1.data.sort == 'teamRoleDesc' && query1.data.dir == 'asc'" dmx-class:sorting_desc="query1.data.sort == 'teamRoleDesc' && query1.data.dir == 'desc'">Team role</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>

                        <tbody is="dmx-repeat" dmx-generator="bs5table" dmx-bind:repeat="scListAllUsers.data.query" id="tableRepeat2" dmx-state="query1" dmx-sort="sort" dmx-order="dir">
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center flex-shrink-0" style="width: 40px; height: 40px;">
                                            <i class="fas fa-user"></i>
                                        </div>
                                        <div>
                                            <div class="fw-semibold" dmx-text="displayName"></div>
                                            <div class="text-muted small" dmx-text="email"></div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border" dmx-text="accessRole"></span>
                                </td>
                                <td dmx-text="teamName"></td>
                                <td dmx-text="teamRoleDesc"></td>
                                <td>
                                    <span class="badge bg-success" dmx-show="userActive == 1">Active</span>
                                    <span class="badge bg-secondary" dmx-show="userActive != 1">Inactive</span>
                                </td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" dmx-bind:href="'/users/edit_user?userid=' + userId" dmx-bind:aria-label="'Edit ' + displayName">
                                        <i class="fas fa-pen me-1"></i>Edit
                                    </a>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="text-center py-5" dmx-show="!scListAllUsers.state.executing && scListAllUsers.data.query.count() == 0">
                    <div class="rounded-circle bg-light text-muted d-inline-flex align-items-center justify-content-center mb-3" style="width: 56px; height: 56px;">
                        <i class="fas fa-users fa-lg"></i>
                    </div>
                    <h3 class="h6 mb-1">No users found</h3>
                    <p class="text-muted small mb-3">Add the first user for this tenant to get started.</p>
                    <a class="btn btn-sm btn-primary" href="/users/create_user">Add user</a>
                </div>
            </div>
        </div>
    </div>
</div>

<meta name="ac:route" content="/users/all_users">
